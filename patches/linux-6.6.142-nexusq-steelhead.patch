+static void tas571x_nq_dump_registers(struct tas571x_private *priv,
+				      struct i2c_client *client,
+				      const char *phase)
+{
+	unsigned int i;
+
+	if (!tas571x_nq_dump_regs)
+		return;
+
+	for (i = 0; i < ARRAY_SIZE(tas571x_nq_dump_reglist); i++) {
+		const struct tas571x_nq_dump_reg *entry =
+			&tas571x_nq_dump_reglist[i];
+		int size = tas571x_register_size(priv, entry->reg);
+		unsigned int value;
+		int ret;
+
+		if (entry->words) {
+			long values[5];
+
+			if (entry->words > ARRAY_SIZE(values)) {
+				dev_warn(&client->dev,
+					 "nq tas571x %s %s[0x%02x] too many words: %zu\n",
+					 phase, entry->name, entry->reg,
+					 entry->words);
+				continue;
+			}
+
+			ret = tas571x_reg_read_multiword(client, entry->reg,
+							 values, entry->words);
+			if (ret) {
+				dev_warn(&client->dev,
+					 "nq tas571x %s %s[0x%02x] read failed: %d\n",
+					 phase, entry->name, entry->reg, ret);
+				continue;
+			}
+
+			switch (entry->words) {
+			case 1:
+				dev_info(&client->dev,
+					 "nq tas571x %s %s[0x%02x]=0x%08lx\n",
+					 phase, entry->name, entry->reg,
+					 values[0]);
+				break;
+			case 2:
+				dev_info(&client->dev,
+					 "nq tas571x %s %s[0x%02x]=0x%08lx 0x%08lx\n",
+					 phase, entry->name, entry->reg,
+					 values[0], values[1]);
+				break;
+			case 5:
+				dev_info(&client->dev,
+					 "nq tas571x %s %s[0x%02x]=0x%08lx 0x%08lx 0x%08lx 0x%08lx 0x%08lx\n",
+					 phase, entry->name, entry->reg,
+					 values[0], values[1], values[2],
+					 values[3], values[4]);
+				break;
+			default:
+				dev_warn(&client->dev,
+					 "nq tas571x %s %s[0x%02x] unsupported word count: %zu\n",
+					 phase, entry->name, entry->reg,
+					 entry->words);
+				break;
+			}
+
+			continue;
+		}
+
+		ret = tas571x_reg_read(client, entry->reg, &value);
+		if (ret) {
+			dev_warn(&client->dev,
+				 "nq tas571x %s %s[0x%02x] read failed: %d\n",
+				 phase, entry->name, entry->reg, ret);
+			continue;
+		}
+
+		dev_info(&client->dev, "nq tas571x %s %s[0x%02x]=0x%0*x\n",
+			 phase, entry->name, entry->reg, size * 2, value);
+	}
+}
