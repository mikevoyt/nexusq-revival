+static void omap_mcbsp_nq_pio_write_word(struct omap_mcbsp *mcbsp, s16 sample)
+{
+	u16 data_reg = mcbsp->pdata->reg_size == 2 ?
+		OMAP_MCBSP_REG_DXR1 : OMAP_MCBSP_REG_DXR;
+
+	omap_mcbsp_write(mcbsp, data_reg, (u16)sample);
+}
+
+static s16 omap_mcbsp_nq_pio_next_sample(struct omap_mcbsp *mcbsp)
+{
+	unsigned int amp = min_t(unsigned int, omap_mcbsp_nq_pio_tone_amp,
+				 32767);
+	u8 idx = mcbsp->nq_pio_phase >> 24;
+	s32 sample = omap_mcbsp_nq_sine_256[idx];
+
+	mcbsp->nq_pio_phase += mcbsp->nq_pio_step;
+
+	return (s16)((sample * (s32)amp) >> 15);
+}
+
+static bool omap_mcbsp_nq_pio_write_next_word(struct omap_mcbsp *mcbsp)
+{
+	s16 sample;
+
+	if (!mcbsp->nq_pio_active)
+		return false;
+
+	if (!mcbsp->nq_pio_word_in_frame) {
+		sample = omap_mcbsp_nq_pio_next_sample(mcbsp);
+		mcbsp->nq_pio_word_in_frame = 1;
+	} else {
+		sample = 0;
+		mcbsp->nq_pio_word_in_frame = 0;
+		if (mcbsp->nq_pio_remaining_frames &&
+		    --mcbsp->nq_pio_remaining_frames == 0)
+			mcbsp->nq_pio_active = false;
+	}
+
+	omap_mcbsp_nq_pio_write_word(mcbsp, sample);
+	mcbsp->nq_pio_words_written++;
+
+	return true;
+}
+
+static void omap_mcbsp_nq_pio_schedule_cleanup(struct omap_mcbsp *mcbsp)
+{
+	if (!omap_mcbsp_nq_pio_detached_stop)
+		return;
+
+	if (mcbsp->nq_pio_stop_deferred || mcbsp->nq_pio_shutdown_deferred)
+		schedule_work(&mcbsp->nq_pio_cleanup_work);
+}
+
+static bool omap_mcbsp_nq_pio_defer_stop(struct omap_mcbsp *mcbsp,
+					 const char *phase)
+{
+	if (!omap_mcbsp_nq_pio_detached_stop || !mcbsp->nq_pio_active)
+		return false;
+
+	mcbsp->nq_pio_stop_deferred = true;
+	dev_info(mcbsp->dev,
+		 "nq pio detached %s deferred active=%d shutdown_deferred=%d\n",
+		 phase, mcbsp->active, mcbsp->nq_pio_shutdown_deferred);
+
+	return true;
+}
+
+static void omap_mcbsp_nq_pio_cleanup_work(struct work_struct *work)
+{
+	struct omap_mcbsp *mcbsp =
+		container_of(work, struct omap_mcbsp, nq_pio_cleanup_work);
+	bool stop_deferred = mcbsp->nq_pio_stop_deferred;
+	bool shutdown_deferred = mcbsp->nq_pio_shutdown_deferred;
+
+	if (!omap_mcbsp_nq_pio_detached_stop || mcbsp->nq_pio_active)
+		return;
+
+	mcbsp->nq_pio_stop_deferred = false;
+	mcbsp->nq_pio_shutdown_deferred = false;
+
+	if (stop_deferred) {
+		omap_mcbsp_stop(mcbsp, SNDRV_PCM_STREAM_PLAYBACK);
+		if (mcbsp->active > 0)
+			mcbsp->active--;
+		else
+			dev_warn(mcbsp->dev,
+				 "nq pio detached cleanup active count was already zero\n");
+	}
+
+	if (shutdown_deferred) {
+		omap_mcbsp_free(mcbsp);
+		mcbsp->configured = 0;
+	}
+
+	dev_info(mcbsp->dev,
+		 "nq pio detached cleanup done stop_deferred=%d shutdown_deferred=%d active=%d configured=%d\n",
+		 stop_deferred, shutdown_deferred, mcbsp->active,
+		 mcbsp->configured);
+}
