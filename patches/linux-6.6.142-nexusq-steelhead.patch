+static void omap_dma_nq_progress_stop(struct omap_chan *c)
+{
+	u64 avg_delta = 0;
+	u64 avg_us = 0;
+
+	if (!c->nq_progress_active)
+		return;
+
+	c->nq_progress_active = false;
+	hrtimer_cancel(&c->nq_progress_timer);
+
+	if (c->nq_progress_samples) {
+		avg_delta = div64_u64(c->nq_progress_total_bytes,
+				      c->nq_progress_samples);
+		avg_us = div64_u64(c->nq_progress_total_us,
+				   c->nq_progress_samples);
+	}
+
+	dev_info(c->vc.chan.device->dev,
+		 "nq progress stop sig=%u channel=%d samples=%llu len=%zu min_delta=%u max_delta=%u avg_delta=%llu zero_delta=%u out_of_range=%u min_us=%lld max_us=%lld avg_us=%llu\n",
+		 c->dma_sig, c->dma_ch, c->nq_progress_samples,
+		 c->nq_progress_len,
+		 c->nq_progress_samples ? c->nq_progress_min_delta : 0,
+		 c->nq_progress_max_delta, avg_delta,
+		 c->nq_progress_zero_delta_samples,
+		 c->nq_progress_out_of_range_samples,
+		 c->nq_progress_samples ? c->nq_progress_min_us : 0,
+		 c->nq_progress_max_us, avg_us);
+
+	omap_dma_nq_progress_dump_trace(c);
+	omap_dma_nq_progress_free_trace(c);
+}
+
+static enum hrtimer_restart omap_dma_nq_progress_timer(struct hrtimer *timer)
+{
+	struct omap_chan *c = container_of(timer, struct omap_chan,
+					  nq_progress_timer);
+	dma_addr_t addr;
+	ktime_t now;
+	s64 elapsed_us;
+	u32 delta;
+	u32 pos;
+
+	if (!c->nq_progress_active || !c->desc || !c->nq_progress_len)
+		return HRTIMER_NORESTART;
+
+	addr = omap_dma_get_src_pos(c);
+	now = ktime_get();
+
+	if (addr < c->nq_progress_base ||
+	    addr >= c->nq_progress_base + c->nq_progress_len) {
+		c->nq_progress_out_of_range_samples++;
+		goto rearm;
+	}
+
+	pos = addr - c->nq_progress_base;
+	if (!c->nq_progress_seen) {
+		c->nq_progress_seen = true;
+		c->nq_progress_last_pos = pos;
+		c->nq_progress_last_ts = now;
+		goto rearm;
+	}
+
+	if (pos >= c->nq_progress_last_pos)
+		delta = pos - c->nq_progress_last_pos;
+	else
+		delta = c->nq_progress_len - c->nq_progress_last_pos + pos;
+
+	elapsed_us = ktime_us_delta(now, c->nq_progress_last_ts);
+	if (!c->nq_progress_samples ||
+	    delta < c->nq_progress_min_delta)
+		c->nq_progress_min_delta = delta;
+	if (delta > c->nq_progress_max_delta)
+		c->nq_progress_max_delta = delta;
+	if (delta == 0)
+		c->nq_progress_zero_delta_samples++;
+	if (!c->nq_progress_samples || elapsed_us < c->nq_progress_min_us)
+		c->nq_progress_min_us = elapsed_us;
+	if (elapsed_us > c->nq_progress_max_us)
+		c->nq_progress_max_us = elapsed_us;
+
+	c->nq_progress_total_bytes += delta;
+	if (elapsed_us > 0)
+		c->nq_progress_total_us += elapsed_us;
+	c->nq_progress_samples++;
+
+	if (c->nq_progress_trace) {
+		if (c->nq_progress_trace_count < c->nq_progress_trace_capacity) {
+			struct omap_dma_nq_progress_sample *s =
+				&c->nq_progress_trace[c->nq_progress_trace_count++];
+
+			s->pos = pos;
+			s->delta = delta;
+			if (elapsed_us < 0)
+				s->elapsed_us = 0;
+			else if (elapsed_us > U32_MAX)
+				s->elapsed_us = U32_MAX;
+			else
+				s->elapsed_us = elapsed_us;
+		} else {
+			c->nq_progress_trace_dropped++;
+		}
+	}
+
+	c->nq_progress_last_pos = pos;
+	c->nq_progress_last_ts = now;
+
+rearm:
+	hrtimer_forward_now(timer,
+			    ms_to_ktime(max_t(unsigned int,
+					      omap_dma_nq_progress_poll_ms, 1)));
+	return HRTIMER_RESTART;
+}
+
+static void omap_dma_nq_progress_start(struct omap_chan *c,
+				       struct omap_desc *d)
+{
+	size_t len;
+
+	if (!omap_dma_nq_progress_poll_ms || !c->cyclic || !d ||
+	    d->dir != DMA_MEM_TO_DEV ||
+	    d->dev_addr != (dma_addr_t)omap_dma_nq_audio_tone_dev_addr)
+		return;
+
+	len = d->sg[0].en * d->sg[0].fn * es_bytes[d->es];
+	if (!len)
+		return;
+
+	omap_dma_nq_progress_stop(c);
+	c->nq_progress_active = true;
+	c->nq_progress_seen = false;
+	c->nq_progress_base = d->sg[0].addr;
+	c->nq_progress_len = len;
+	c->nq_progress_last_pos = 0;
+	c->nq_progress_last_ts = 0;
+	c->nq_progress_samples = 0;
+	c->nq_progress_total_bytes = 0;
+	c->nq_progress_total_us = 0;
+	c->nq_progress_min_delta = U32_MAX;
+	c->nq_progress_max_delta = 0;
+	c->nq_progress_zero_delta_samples = 0;
+	c->nq_progress_out_of_range_samples = 0;
+	c->nq_progress_min_us = S64_MAX;
+	c->nq_progress_max_us = 0;
+	omap_dma_nq_progress_free_trace(c);
+	if (omap_dma_nq_progress_trace_samples) {
+		c->nq_progress_trace_capacity =
+			min_t(unsigned int, omap_dma_nq_progress_trace_samples,
+			      8192);
+		c->nq_progress_trace =
+			kcalloc(c->nq_progress_trace_capacity,
+				sizeof(*c->nq_progress_trace), GFP_ATOMIC);
+		if (!c->nq_progress_trace) {
+			dev_warn(c->vc.chan.device->dev,
+				 "nq progress trace allocation failed samples=%u\n",
+				 c->nq_progress_trace_capacity);
+			c->nq_progress_trace_capacity = 0;
+		}
+	}
+
+	dev_info(c->vc.chan.device->dev,
+		 "nq progress start sig=%u channel=%d interval_ms=%u trace_samples=%u base=%pad len=%zu en=%u fn=%u es=%u\n",
+		 c->dma_sig, c->dma_ch, omap_dma_nq_progress_poll_ms,
+		 c->nq_progress_trace_capacity,
+		 &c->nq_progress_base, c->nq_progress_len,
+		 d->sg[0].en, d->sg[0].fn, d->es);
+	hrtimer_start(&c->nq_progress_timer,
+		      ms_to_ktime(max_t(unsigned int,
+					omap_dma_nq_progress_poll_ms, 1)),
+			      HRTIMER_MODE_REL);
+}
+
+static void omap_dma_nq_fake_period_stop(struct omap_chan *c)
+{
+	if (!c->nq_fake_period_active)
+		return;
+
+	c->nq_fake_period_active = false;
+	hrtimer_cancel(&c->nq_fake_period_timer);
+	dev_info(c->vc.chan.device->dev,
+		 "nq fake-period stop sig=%u channel=%d callbacks=%llu skipped=%llu\n",
+		 c->dma_sig, c->dma_ch, c->nq_fake_period_count,
+		 c->nq_fake_period_skipped);
+}
+
+static enum hrtimer_restart omap_dma_nq_fake_period_timer(struct hrtimer *timer)
+{
+	struct omap_chan *c = container_of(timer, struct omap_chan,
+					  nq_fake_period_timer);
+	struct omap_desc *d;
+	unsigned long flags;
+
+	if (!c->nq_fake_period_active || !c->running)
+		return HRTIMER_NORESTART;
+
+	if (spin_trylock_irqsave(&c->vc.lock, flags)) {
+		d = c->desc;
+		if (d && c->cyclic) {
+			c->nq_fake_period_count++;
+			vchan_cyclic_callback(&d->vd);
+		}
+		spin_unlock_irqrestore(&c->vc.lock, flags);
+	} else {
+		c->nq_fake_period_skipped++;
+	}
+
+	if (!c->nq_fake_period_active)
+		return HRTIMER_NORESTART;
+
+	hrtimer_forward_now(timer, c->nq_fake_period_interval);
+	return HRTIMER_RESTART;
+}
+
+static void omap_dma_nq_fake_period_start(struct omap_chan *c,
+					  struct omap_desc *d)
+{
+	u64 period_ns;
+	unsigned int rate = omap_dma_nq_audio_tone_rate;
+
+	if (!omap_dma_nq_audio_tone_fake_period || !c->cyclic || !d ||
+	    !d->nq_audio_tone_active || !d->nq_audio_tone_period_len)
+		return;
+	if (!rate)
+		rate = 48000;
+
+	period_ns = div_u64((u64)d->nq_audio_tone_period_len * NSEC_PER_SEC,
+			    rate * 2U * sizeof(s16));
+	if (!period_ns)
+		return;
+
+	omap_dma_nq_fake_period_stop(c);
+	c->nq_fake_period_interval = ns_to_ktime(period_ns);
+	c->nq_fake_period_count = 0;
+	c->nq_fake_period_skipped = 0;
+	c->nq_fake_period_active = true;
+	dev_info(c->vc.chan.device->dev,
+		 "nq fake-period start sig=%u channel=%d period_len=%zu rate=%u interval_ns=%llu\n",
+		 c->dma_sig, c->dma_ch, d->nq_audio_tone_period_len, rate,
+		 period_ns);
+	hrtimer_start(&c->nq_fake_period_timer, c->nq_fake_period_interval,
+		      HRTIMER_MODE_REL);
+}
