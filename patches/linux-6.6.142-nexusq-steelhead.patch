+		steelhead_tas5713_dai_format_name = "i2s";
+	} else if (!strcmp(str, "left_j")) {
+		steelhead_tas5713_dai_format = SND_SOC_DAIFMT_LEFT_J;
+		steelhead_tas5713_dai_format_name = "left_j";
+	} else if (!strcmp(str, "right_j")) {
+		steelhead_tas5713_dai_format = SND_SOC_DAIFMT_RIGHT_J;
+		steelhead_tas5713_dai_format_name = "right_j";
+	} else {
+		pr_warn("steelhead-tas5713: ignoring unknown nq.audio_format=%s\n",
+			str);
+	}
+
+	return 1;
+}
+__setup("nq.audio_format=", steelhead_tas5713_audio_format_setup);
+
+#ifndef MODULE
+static int steelhead_tas5713_bclk_fs_setup(char *str)
+{
+	int ret = kstrtouint(str, 0, &steelhead_tas5713_bclk_fs_override);
+
+	if (ret)
+		pr_warn("steelhead-tas5713: ignoring invalid nq.bclk_fs=%s\n",
+			str);
+
+	return 1;
+}
+__setup("nq.bclk_fs=", steelhead_tas5713_bclk_fs_setup);
+#endif
