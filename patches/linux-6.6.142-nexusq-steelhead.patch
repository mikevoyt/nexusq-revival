+static int steelhead_tas5713_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct device_node *np = dev->of_node;
+	struct steelhead_tas5713 *priv;
+	struct snd_soc_card *card;
+	struct device_node *cpu_np;
+	struct device_node *codec_np;
+	int ret;
+
+	if (!np)
+		return -ENODEV;
+
+	if (steelhead_tas5713_audio_inversion_param)
+		steelhead_tas5713_audio_inversion_setup(
+			steelhead_tas5713_audio_inversion_param);
+	if (steelhead_tas5713_audio_format_param)
+		steelhead_tas5713_audio_format_setup(
+			steelhead_tas5713_audio_format_param);
+
+	priv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	cpu_np = of_parse_phandle(np, "google,mcbsp", 0);
+	if (!cpu_np)
+		return dev_err_probe(dev, -EINVAL, "missing google,mcbsp\n");
+
+	codec_np = of_parse_phandle(np, "google,audio-codec", 0);
+	if (!codec_np) {
+		of_node_put(cpu_np);
+		return dev_err_probe(dev, -EINVAL, "missing google,audio-codec\n");
+	}
+
+	steelhead_tas5713_link.cpus->of_node = cpu_np;
+	steelhead_tas5713_link.platforms->of_node = cpu_np;
+	steelhead_tas5713_link.codecs->of_node = codec_np;
+	if (steelhead_tas5713_link_fmt)
+		steelhead_tas5713_link.dai_fmt =
+			steelhead_tas5713_dai_fmt(SND_SOC_DAIFMT_CBC_CFC);
+	else
+		steelhead_tas5713_link.dai_fmt = 0;
+	if (steelhead_tas5713_trigger_ldc) {
+		steelhead_tas5713_link.trigger_start = SND_SOC_TRIGGER_ORDER_LDC;
+		steelhead_tas5713_link.trigger_stop = SND_SOC_TRIGGER_ORDER_LDC;
+	}
+
+	priv->codec_mclk = devm_clk_get_optional(dev, "codec-mclk");
+	if (IS_ERR(priv->codec_mclk))
+		return dev_err_probe(dev, PTR_ERR(priv->codec_mclk),
+				     "failed to get codec-mclk\n");
+
+	priv->codec_src = steelhead_tas5713_get_legacy_clk(dev, "auxclk1_src_ck");
+	if (IS_ERR(priv->codec_src))
+		return PTR_ERR(priv->codec_src);
+
+	priv->codec_src_parent =
+		steelhead_tas5713_get_legacy_clk(dev, "dpll_per_m3x2_ck");
+	if (IS_ERR(priv->codec_src_parent))
+		return PTR_ERR(priv->codec_src_parent);
+
+	priv->mcbsp_clk = devm_clk_get(dev, "mcbsp-sync");
+	if (IS_ERR(priv->mcbsp_clk))
+		return dev_err_probe(dev, PTR_ERR(priv->mcbsp_clk),
+				     "failed to get mcbsp-sync\n");
+
+	priv->mcbsp_parent = devm_clk_get_optional(dev, "mcbsp-parent");
+	if (IS_ERR(priv->mcbsp_parent))
+		return dev_err_probe(dev, PTR_ERR(priv->mcbsp_parent),
+				     "failed to get mcbsp-parent\n");
+
+	if (priv->codec_src_parent) {
+		ret = clk_set_rate(priv->codec_src_parent, 61440000);
+		if (ret)
+			dev_warn(dev, "failed to set codec parent rate: %d\n", ret);
+	}
+
+	if (priv->codec_src && priv->codec_src_parent) {
+		ret = clk_set_parent(priv->codec_src, priv->codec_src_parent);
+		if (ret)
+			dev_warn(dev, "failed to parent codec clock: %d\n", ret);
+	}
+
+	if (priv->codec_mclk) {
+		ret = clk_set_rate(priv->codec_mclk, 12288000);
+		if (ret)
+			dev_warn(dev, "failed to set codec mclk: %d\n", ret);
+	}
+
+	if (priv->mcbsp_parent) {
+		ret = clk_set_parent(priv->mcbsp_clk, priv->mcbsp_parent);
+		if (ret)
+			return dev_err_probe(dev, ret,
+					     "failed to parent mcbsp clock\n");
+	}
+
+	dev_info(dev, "clock rates: codec-mclk=%lu codec-src=%lu mcbsp=%lu\n",
+		 priv->codec_mclk ? clk_get_rate(priv->codec_mclk) : 0,
+		 priv->codec_src ? clk_get_rate(priv->codec_src) : 0,
+		 clk_get_rate(priv->mcbsp_clk));
+
+	card = &priv->card;
+	card->dev = dev;
+	card->owner = THIS_MODULE;
+	card->dai_link = &steelhead_tas5713_link;
+	card->num_links = 1;
+	card->dapm_widgets = steelhead_tas5713_widgets;
+	card->num_dapm_widgets = ARRAY_SIZE(steelhead_tas5713_widgets);
+	card->dapm_routes = steelhead_tas5713_routes;
+	card->num_dapm_routes = ARRAY_SIZE(steelhead_tas5713_routes);
+
+	ret = snd_soc_of_parse_card_name(card, "ti,model");
+	if (ret)
+		card->name = "Steelhead TAS5713";
+
+	snd_soc_card_set_drvdata(card, priv);
+
+	dev_info(dev, "using DAI format %s inversion %s trigger_order=%s legacy_s16_only=%d codec_power_first=%d skip_codec_fmt=%d link_fmt=%d dai_fmt=0x%x\n",
+		 steelhead_tas5713_dai_format_name,
+		 steelhead_tas5713_dai_inversion_name,
+		 steelhead_tas5713_trigger_ldc ? "ldc" : "default",
+		 steelhead_tas5713_legacy_s16_only,
+		 steelhead_tas5713_codec_power_first,
+		 steelhead_tas5713_skip_codec_fmt,
+		 steelhead_tas5713_link_fmt,
+		 steelhead_tas5713_link.dai_fmt);
+
+	ret = devm_snd_soc_register_card(dev, card);
+	if (ret)
+		return dev_err_probe(dev, ret, "failed to register card\n");
+
+	dev_info(dev, "registered Steelhead TAS5713 audio card\n");
+
+	return 0;
+}
+
+static const struct of_device_id steelhead_tas5713_of_match[] = {
+	{ .compatible = "google,steelhead-tas5713" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, steelhead_tas5713_of_match);
+
+static struct platform_driver steelhead_tas5713_driver = {
+	.driver = {
+		.name = "steelhead-tas5713",
+		.of_match_table = steelhead_tas5713_of_match,
+	},
+	.probe = steelhead_tas5713_probe,
+};
+module_platform_driver(steelhead_tas5713_driver);
+
+MODULE_DESCRIPTION("Google Nexus Q / Steelhead TAS5713 ASoC machine driver");
+MODULE_AUTHOR("Google, Inc.; Nexus Q revival contributors");
+MODULE_LICENSE("GPL");
