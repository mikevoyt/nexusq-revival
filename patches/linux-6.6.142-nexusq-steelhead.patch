+	if (omap_mcbsp_nq_srgr1_override >= 0) {
+		regs->srgr1 = omap_mcbsp_nq_srgr1_override;
+		changed = true;
+	}
+	if (omap_mcbsp_nq_srgr2_override >= 0) {
+		regs->srgr2 = omap_mcbsp_nq_srgr2_override;
+		changed = true;
+	}
+	if (omap_mcbsp_nq_pcr0_override >= 0) {
+		regs->pcr0 = omap_mcbsp_nq_pcr0_override;
+		changed = true;
+	}
+	if (omap_mcbsp_nq_xccr_override >= 0) {
+		regs->xccr = omap_mcbsp_nq_xccr_override;
