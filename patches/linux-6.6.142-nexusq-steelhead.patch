+MODULE_PARM_DESC(nq_ldc, "Use LDC trigger order for Nexus Q audio diagnostics");
+module_param_named(nq_legacy_s16_only, steelhead_tas5713_legacy_s16_only,
+		   bool, 0644);
+MODULE_PARM_DESC(nq_legacy_s16_only,
+		 "Constrain Nexus Q TAS5713 playback to legacy S16_LE format");
+module_param_named(nq_codec_power_first,
+		   steelhead_tas5713_codec_power_first, bool, 0644);
+MODULE_PARM_DESC(nq_codec_power_first,
+		 "Run TAS5713 codec unmute from the Steelhead link trigger before DMA start");
+module_param_named(nq_codec_mclk_startup,
+		   steelhead_tas5713_codec_mclk_startup, bool, 0644);
+MODULE_PARM_DESC(nq_codec_mclk_startup,
+		 "Enable the TAS5713 MCLK from the Steelhead machine startup/shutdown hooks");
+module_param_named(nq_mcbsp_clk_startup,
+		   steelhead_tas5713_mcbsp_clk_startup, bool, 0644);
+MODULE_PARM_DESC(nq_mcbsp_clk_startup,
+		 "Diagnostic only: enable McBSP fclk from the Steelhead machine startup/shutdown hooks");
+module_param_named(nq_mcbsp_clk_hw_params,
+		   steelhead_tas5713_mcbsp_clk_hw_params, bool, 0644);
+MODULE_PARM_DESC(nq_mcbsp_clk_hw_params,
+		 "Diagnostic only: keep McBSP sync clock enabled from hw_params to hw_free, matching the downstream Steelhead driver");
+module_param_named(nq_skip_codec_fmt,
+		   steelhead_tas5713_skip_codec_fmt, bool, 0644);
+MODULE_PARM_DESC(nq_skip_codec_fmt,
+		 "Skip TAS5713 codec DAI set_fmt to match the downstream Steelhead driver");
+module_param_named(nq_link_fmt,
+		   steelhead_tas5713_link_fmt, bool, 0444);
+MODULE_PARM_DESC(nq_link_fmt,
+		 "Apply the static ASoC link dai_fmt during card registration");
+module_param_named(nq_audio_inversion,
+		   steelhead_tas5713_audio_inversion_param, charp, 0444);
+MODULE_PARM_DESC(nq_audio_inversion,
+		 "Nexus Q DAI clock inversion: nb-nf, nb-if, ib-nf, or ib-if");
+module_param_named(nq_audio_format,
+		   steelhead_tas5713_audio_format_param, charp, 0444);
+MODULE_PARM_DESC(nq_audio_format,
+		 "Nexus Q DAI format: i2s, left_j, or right_j");
+module_param_named(nq_bclk_fs, steelhead_tas5713_bclk_fs_override, uint,
+		   0444);
+MODULE_PARM_DESC(nq_bclk_fs,
+		 "Override Nexus Q BCLK frame size, 0 uses physical width * channels");
+module_param_named(nq_period_size, steelhead_tas5713_period_size, uint, 0644);
+MODULE_PARM_DESC(nq_period_size,
+		 "Constrain Nexus Q playback period size in frames, 0 disables");
+module_param_named(nq_periods, steelhead_tas5713_periods, uint, 0644);
+MODULE_PARM_DESC(nq_periods,
+		 "Constrain Nexus Q playback period count, 0 disables");
