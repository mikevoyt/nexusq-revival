+static void tas571x_nq_err_poll_start(struct tas571x_private *priv,
+				      struct i2c_client *client);
+static void tas571x_nq_err_poll_stop(struct tas571x_private *priv,
+				     struct i2c_client *client,
+				     const char *phase);
+
+static void tas571x_nq_async_unmute_work(struct work_struct *work)
+{
+	struct delayed_work *delayed = to_delayed_work(work);
+	struct tas571x_private *priv =
+		container_of(delayed, struct tas571x_private,
+			     nq_async_unmute_work);
+	struct i2c_client *client = priv->client;
+	unsigned int delay_us = priv->chip->shutdown_delay_us;
+	int ret;
+
+	mutex_lock(&priv->nq_stream_lock);
+
+	if (tas571x_nq_dump_regs)
+		dev_info(&client->dev,
+			 "nq tas571x async legacy-stream-reinit begin delay_ms=%d\n",
+			 tas571x_nq_async_legacy_stream_reinit_ms);
+
+	ret = tas571x_legacy_stream_reinit(priv, client,
+					   priv->chip->keep_mclk_after_init);
+	if (!ret)
+		ret = regmap_write(priv->regmap, TAS571X_SYS_CTRL_2_REG, 0);
+
+	if (!ret) {
+		if (delay_us)
+			usleep_range(delay_us, delay_us + 1000);
+		else
+			usleep_range(1000, 2000);
+		tas571x_nq_dump_registers(priv, client, "async-unmute");
+		priv->stream_mute_valid = true;
+		priv->stream_muted = false;
+		tas571x_nq_err_poll_start(priv, client);
+	} else {
+		dev_err(&client->dev,
+			"nq tas571x async legacy-stream-reinit failed: %d\n",
+			ret);
+	}
+
+	mutex_unlock(&priv->nq_stream_lock);
+}
+
+static void tas571x_nq_err_poll_work(struct work_struct *work)
+{
+	struct delayed_work *delayed = to_delayed_work(work);
+	struct tas571x_private *priv =
+		container_of(delayed, struct tas571x_private,
+			     nq_err_poll_work);
+	struct i2c_client *client = priv->client;
+	unsigned int err = 0;
+	unsigned int sys2 = 0;
+	unsigned int elapsed_ms;
+	bool log_sample = false;
+	int ret_err;
+	int ret_sys2;
+
+	if (!READ_ONCE(priv->nq_err_poll_enabled) ||
+	    tas571x_nq_err_poll_ms <= 0)
+		return;
+
+	ret_err = tas571x_reg_read(client, TAS571X_ERR_STATUS_REG, &err);
+	ret_sys2 = tas571x_reg_read(client, TAS571X_SYS_CTRL_2_REG, &sys2);
+	elapsed_ms = jiffies_to_msecs(jiffies -
+				      priv->nq_err_poll_start_jiffies);
+
+	priv->nq_err_poll_samples++;
+	if (ret_err || ret_sys2) {
+		priv->nq_err_poll_read_errors++;
+		dev_warn_ratelimited(&client->dev,
+				     "nq tas571x err-poll sample=%u elapsed_ms=%u read failed err_ret=%d sys2_ret=%d\n",
+				     priv->nq_err_poll_samples, elapsed_ms,
+				     ret_err, ret_sys2);
+	} else {
+		if (err)
+			priv->nq_err_poll_err_nonzero++;
+
+		if (!priv->nq_err_poll_have_last) {
+			log_sample = true;
+		} else {
+			if (err != priv->nq_err_poll_err_last) {
+				priv->nq_err_poll_err_changes++;
+				log_sample = true;
+			}
+			if (sys2 != priv->nq_err_poll_sys2_last) {
+				priv->nq_err_poll_sys2_changes++;
+				log_sample = true;
+			}
+		}
+
+		priv->nq_err_poll_have_last = true;
+		priv->nq_err_poll_err_last = err;
+		priv->nq_err_poll_sys2_last = sys2;
+
+		if (log_sample)
+			dev_info(&client->dev,
+				 "nq tas571x err-poll sample=%u elapsed_ms=%u err=0x%02x sys2=0x%02x err_changes=%u sys2_changes=%u\n",
