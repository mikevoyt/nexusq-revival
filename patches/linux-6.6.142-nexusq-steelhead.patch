@@ -0,0 +1,446 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Google Nexus Q / Steelhead AVR front panel input driver.
+ *
+ * The front panel ATmega328P reports debounced capacitive controls over an
+ * I2C event FIFO. This driver exposes those controls as normal evdev keys.
+ */
+
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/i2c.h>
+#include <linux/input.h>
+#include <linux/interrupt.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/workqueue.h>
+
+#define STEELHEAD_AVR_KEY_EVENT_FIFO	0x00
+#define STEELHEAD_AVR_KEY_EVENT_DOWN	0x80
+#define STEELHEAD_AVR_KEY_EVENT_MASK	0x3f
+#define STEELHEAD_AVR_KEY_EVENT_RESET	0xfe
+#define STEELHEAD_AVR_KEY_EVENT_EMPTY	0xff
+
+#define STEELHEAD_AVR_KEY_MUTE_THRESHOLD	0x01
+
+#define STEELHEAD_AVR_LED_MODE			0x02
+#define STEELHEAD_AVR_LED_MODE_BOOT_ANIMATION	0x00
+#define STEELHEAD_AVR_LED_MODE_HOST_AUTO_COMMIT	0x01
+#define STEELHEAD_AVR_LED_MODE_HOST		0x02
+#define STEELHEAD_AVR_LED_MODE_POWER_UP		0x03
+#define STEELHEAD_AVR_LED_SET_ALL		0x03
+#define STEELHEAD_AVR_LED_COMMIT		0x05
+#define STEELHEAD_AVR_LED_COMMIT_NOW		0x00
+#define STEELHEAD_AVR_LED_SET_MUTE		0x06
+#define STEELHEAD_AVR_LED_COUNT			0x07
+#define STEELHEAD_AVR_HW_TYPE			0x08
+#define STEELHEAD_AVR_HW_REVISION		0x09
+#define STEELHEAD_AVR_FW_VERSION	0x0a
+
+#define STEELHEAD_AVR_KEY_MUTE		0x00
+#define STEELHEAD_AVR_KEY_VOLUME_UP	0x01
+#define STEELHEAD_AVR_KEY_VOLUME_DOWN	0x02
+
+#define STEELHEAD_AVR_MAX_EVENTS	64
+#define STEELHEAD_AVR_I2C_ATTEMPTS	5
+#define STEELHEAD_AVR_DEFAULT_POLL_MS	50
+
+static unsigned int poll_ms = STEELHEAD_AVR_DEFAULT_POLL_MS;
+module_param(poll_ms, uint, 0644);
+MODULE_PARM_DESC(poll_ms,
+		 "Polling interval in ms when no IRQ is provided; 0 disables polling");
+
+static bool force_poll;
+module_param(force_poll, bool, 0644);
+MODULE_PARM_DESC(force_poll,
+		 "Poll the event FIFO even when an IRQ is available");
+
+static bool debug_events;
+module_param(debug_events, bool, 0644);
+MODULE_PARM_DESC(debug_events, "Log raw event FIFO bytes");
+
+static bool legacy_init = true;
+module_param(legacy_init, bool, 0644);
+MODULE_PARM_DESC(legacy_init,
+		 "Run the legacy LED/control initialization sequence");
+
+static unsigned int reset_pulse_ms;
+module_param(reset_pulse_ms, uint, 0644);
+MODULE_PARM_DESC(reset_pulse_ms,
+		 "Assert AVR reset for this many ms during probe; 0 disables");
+
+struct steelhead_avr {
+	struct device *dev;
+	struct i2c_client *client;
+	struct input_dev *input;
+	struct gpio_desc *reset_gpio;
+	struct delayed_work poll_work;
+	struct mutex i2c_lock;
+	bool polling;
+	u8 led_mode;
+	u8 led_count;
+};
+
+static const unsigned short steelhead_avr_keymap[] = {
+	[STEELHEAD_AVR_KEY_MUTE] = KEY_MUTE,
+	[STEELHEAD_AVR_KEY_VOLUME_UP] = KEY_VOLUMEUP,
+	[STEELHEAD_AVR_KEY_VOLUME_DOWN] = KEY_VOLUMEDOWN,
+};
+
+static void steelhead_avr_drain_events(struct steelhead_avr *avr);
+
+static int steelhead_avr_read(struct steelhead_avr *avr, u8 reg, u8 *buf,
+			      size_t len)
+{
+	struct i2c_client *client = avr->client;
+	int ret = 0;
+	int try;
+
+	mutex_lock(&avr->i2c_lock);
+	for (try = 0; try < STEELHEAD_AVR_I2C_ATTEMPTS; try++) {
+		ret = i2c_smbus_write_byte(client, reg);
+		if (!ret)
+			break;
+		usleep_range(1000, 2000);
+	}
+	if (ret) {
+		mutex_unlock(&avr->i2c_lock);
+		return ret;
+	}
+
+	/*
+	 * The legacy driver found that the AVR needs a small settling delay
+	 * between selecting the register and reading its payload. Without it
+	 * the transaction can succeed electrically while returning bad data.
+	 */
+	usleep_range(50, 100);
+
+	for (try = 0; try < STEELHEAD_AVR_I2C_ATTEMPTS; try++) {
+		ret = i2c_master_recv(client, buf, len);
+		if (ret == len) {
+			mutex_unlock(&avr->i2c_lock);
+			return 0;
+		}
+		if (ret < 0)
+			usleep_range(1000, 2000);
+	}
+	mutex_unlock(&avr->i2c_lock);
+
+	return ret < 0 ? ret : -EIO;
+}
+
+static int steelhead_avr_write_byte(struct steelhead_avr *avr, u8 reg, u8 val)
+{
+	struct i2c_client *client = avr->client;
+	int ret = 0;
+	int try;
+
+	mutex_lock(&avr->i2c_lock);
+	for (try = 0; try < STEELHEAD_AVR_I2C_ATTEMPTS; try++) {
+		ret = i2c_smbus_write_byte_data(client, reg, val);
+		if (!ret)
+			break;
+		usleep_range(1000, 2000);
+	}
+	mutex_unlock(&avr->i2c_lock);
+
+	return ret;
+}
+
+static int steelhead_avr_write_block(struct steelhead_avr *avr, u8 reg,
+				     const u8 *buf, size_t len)
+{
+	struct i2c_client *client = avr->client;
+	int ret = 0;
+	int try;
+
+	mutex_lock(&avr->i2c_lock);
+	for (try = 0; try < STEELHEAD_AVR_I2C_ATTEMPTS; try++) {
+		ret = i2c_smbus_write_i2c_block_data(client, reg, len, buf);
+		if (!ret)
+			break;
+		usleep_range(1000, 2000);
+	}
+	mutex_unlock(&avr->i2c_lock);
+
+	return ret;
+}
+
+static int steelhead_avr_read_event(struct steelhead_avr *avr, u8 *event)
+{
+	return steelhead_avr_read(avr, STEELHEAD_AVR_KEY_EVENT_FIFO, event, 1);
+}
+
+static void steelhead_avr_report_event(struct steelhead_avr *avr, u8 event)
+{
+	unsigned int key;
+	bool down;
+
+	if (event == STEELHEAD_AVR_KEY_EVENT_RESET) {
+		dev_info(avr->dev, "front panel AVR reset notification\n");
+		return;
+	}
+
+	down = event & STEELHEAD_AVR_KEY_EVENT_DOWN;
+	event &= STEELHEAD_AVR_KEY_EVENT_MASK;
+
+	if (event >= ARRAY_SIZE(steelhead_avr_keymap) ||
+	    !steelhead_avr_keymap[event]) {
+		dev_dbg(avr->dev, "ignoring unknown key event 0x%02x\n", event);
+		return;
+	}
+
+	key = steelhead_avr_keymap[event];
+	input_event(avr->input, EV_MSC, MSC_SCAN, event);
+	input_report_key(avr->input, key, down);
+	input_sync(avr->input);
+
+	if (debug_events)
+		dev_info(avr->dev, "reported key %u %s\n", key,
+			 down ? "down" : "up");
+}
+
+static irqreturn_t steelhead_avr_irq_thread(int irq, void *data)
+{
+	struct steelhead_avr *avr = data;
+
+	steelhead_avr_drain_events(avr);
+
+	return IRQ_HANDLED;
+}
+
+static void steelhead_avr_drain_events(struct steelhead_avr *avr)
+{
+	int i;
+
+	for (i = 0; i < STEELHEAD_AVR_MAX_EVENTS; i++) {
+		u8 event = STEELHEAD_AVR_KEY_EVENT_EMPTY;
+		int ret;
+
+		ret = steelhead_avr_read_event(avr, &event);
+		if (ret) {
+			dev_err_ratelimited(avr->dev,
+					    "failed to read event FIFO: %d\n",
+					    ret);
+			break;
+		}
+
+		if (event == STEELHEAD_AVR_KEY_EVENT_EMPTY)
+			break;
+
+		if (debug_events)
+			dev_info(avr->dev, "event FIFO byte 0x%02x\n", event);
+
+		steelhead_avr_report_event(avr, event);
+	}
+
+	if (debug_events && i == 0)
+		dev_info_ratelimited(avr->dev, "event FIFO empty\n");
+
+	if (i == STEELHEAD_AVR_MAX_EVENTS)
+		dev_warn_ratelimited(avr->dev, "event FIFO did not drain\n");
+}
+
+static void steelhead_avr_poll_work(struct work_struct *work)
+{
+	struct steelhead_avr *avr =
+		container_of(to_delayed_work(work), struct steelhead_avr,
+			     poll_work);
+
+	steelhead_avr_drain_events(avr);
+
+	if (poll_ms)
+		schedule_delayed_work(&avr->poll_work,
+				      msecs_to_jiffies(poll_ms));
+}
+
+static int steelhead_avr_hw_init(struct steelhead_avr *avr)
+{
+	u8 version[2];
+	u8 black[3] = { 0, 0, 0 };
+	u8 hw_type = 0;
+	u8 hw_rev = 0;
+	int ret;
+
+	if (avr->reset_gpio) {
+		if (reset_pulse_ms) {
+			dev_info(avr->dev, "pulsing AVR reset for %u ms\n",
+				 reset_pulse_ms);
+			gpiod_set_value_cansleep(avr->reset_gpio, 1);
+			msleep(reset_pulse_ms);
+		}
+		gpiod_set_value_cansleep(avr->reset_gpio, 0);
+		msleep(reset_pulse_ms ? 250 : 20);
+	}
+
+	ret = steelhead_avr_read(avr, STEELHEAD_AVR_FW_VERSION, version,
+				 sizeof(version));
+	if (ret)
+		return dev_err_probe(avr->dev, ret,
+				     "failed to read firmware version\n");
+
+	dev_info(avr->dev, "front panel AVR firmware %u.%u\n",
+		 version[0], version[1]);
+
+	if (!legacy_init)
+		return 0;
+
+	ret = steelhead_avr_write_block(avr, STEELHEAD_AVR_LED_SET_MUTE,
+					black, sizeof(black));
+	if (ret)
+		dev_warn(avr->dev, "failed to clear mute LED: %d\n", ret);
+
+	ret = steelhead_avr_read(avr, STEELHEAD_AVR_LED_COUNT,
+				 &avr->led_count, sizeof(avr->led_count));
+	if (ret) {
+		dev_warn(avr->dev, "failed to read LED count: %d\n", ret);
+		avr->led_count = 32;
+	}
+
+	ret = steelhead_avr_read(avr, STEELHEAD_AVR_LED_MODE,
+				 &avr->led_mode, sizeof(avr->led_mode));
+	if (ret) {
+		dev_warn(avr->dev, "failed to read LED mode: %d\n", ret);
+		avr->led_mode = STEELHEAD_AVR_LED_MODE_HOST_AUTO_COMMIT;
+	}
+
+	steelhead_avr_read(avr, STEELHEAD_AVR_HW_TYPE, &hw_type,
+			   sizeof(hw_type));
+	steelhead_avr_read(avr, STEELHEAD_AVR_HW_REVISION, &hw_rev,
+			   sizeof(hw_rev));
+
+	dev_info(avr->dev,
+		 "legacy init: led_count=%u led_mode=%u hw_type=%u hw_rev=%u\n",
+		 avr->led_count, avr->led_mode, hw_type, hw_rev);
+
+	return 0;
+}
+
+static int steelhead_avr_probe(struct i2c_client *client)
+{
+	struct device *dev = &client->dev;
+	struct steelhead_avr *avr;
+	struct input_dev *input;
+	int irq;
+	int i;
+	int ret;
+
+	avr = devm_kzalloc(dev, sizeof(*avr), GFP_KERNEL);
+	if (!avr)
+		return -ENOMEM;
+
+	avr->dev = dev;
+	avr->client = client;
+	mutex_init(&avr->i2c_lock);
+	i2c_set_clientdata(client, avr);
+
+	avr->reset_gpio = devm_gpiod_get_optional(dev, "reset",
+						  GPIOD_OUT_LOW);
+	if (IS_ERR(avr->reset_gpio))
+		return dev_err_probe(dev, PTR_ERR(avr->reset_gpio),
+				     "failed to get reset GPIO\n");
+
+	irq = client->irq;
+	if (irq <= 0) {
+		struct gpio_desc *irq_gpio;
+
+		irq_gpio = devm_gpiod_get_optional(dev, "interrupt", GPIOD_IN);
+		if (IS_ERR(irq_gpio))
+			return dev_err_probe(dev, PTR_ERR(irq_gpio),
+					     "failed to get interrupt GPIO\n");
+		if (irq_gpio) {
+			irq = gpiod_to_irq(irq_gpio);
+			if (irq < 0)
+				return dev_err_probe(dev, irq,
+						     "failed to map IRQ\n");
+		}
+	}
+
+	input = devm_input_allocate_device(dev);
+	if (!input)
+		return -ENOMEM;
+
+	avr->input = input;
+	input->name = "Steelhead Front Panel";
+	input->phys = "steelhead-avr/input0";
+	input->id.bustype = BUS_I2C;
+	input->id.vendor = 0x18d1;
+	input->id.product = 0x4e23;
+	input->id.version = 0x0001;
+
+	input_set_capability(input, EV_MSC, MSC_SCAN);
+	for (i = 0; i < ARRAY_SIZE(steelhead_avr_keymap); i++)
+		input_set_capability(input, EV_KEY, steelhead_avr_keymap[i]);
+
+	ret = steelhead_avr_hw_init(avr);
+	if (ret)
+		return ret;
+
+	if (irq > 0) {
+		ret = devm_request_threaded_irq(dev, irq, NULL,
+						steelhead_avr_irq_thread,
+						IRQF_ONESHOT | IRQF_TRIGGER_LOW,
+						"steelhead-avr", avr);
+		if (ret)
+			return dev_err_probe(dev, ret, "failed to request IRQ\n");
+		dev_info(dev, "using IRQ %d\n", irq);
+	}
+
+	if ((irq <= 0 || force_poll) && poll_ms) {
+		INIT_DELAYED_WORK(&avr->poll_work, steelhead_avr_poll_work);
+		avr->polling = true;
+		schedule_delayed_work(&avr->poll_work,
+				      msecs_to_jiffies(poll_ms));
+		dev_info(dev, "%s; polling every %u ms\n",
+			 irq > 0 ? "force_poll enabled" : "no IRQ provided",
+			 poll_ms);
+	} else if (irq <= 0) {
+		return dev_err_probe(dev, -ENXIO, "missing IRQ and polling disabled\n");
+	}
+
+	ret = input_register_device(input);
+	if (ret)
+		return dev_err_probe(dev, ret, "failed to register input\n");
+
+	dev_info(dev, "Steelhead front panel input ready\n");
+
+	return 0;
+}
+
+static void steelhead_avr_remove(struct i2c_client *client)
+{
+	struct steelhead_avr *avr = i2c_get_clientdata(client);
+
+	if (avr && avr->polling)
+		cancel_delayed_work_sync(&avr->poll_work);
+	if (avr && legacy_init)
+		steelhead_avr_write_byte(avr, STEELHEAD_AVR_LED_MODE,
+					 STEELHEAD_AVR_LED_MODE_POWER_UP);
+}
+
+static const struct of_device_id steelhead_avr_of_match[] = {
+	{ .compatible = "google,steelhead-avr" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, steelhead_avr_of_match);
+
+static const struct i2c_device_id steelhead_avr_id[] = {
+	{ "steelhead-avr" },
+	{ }
+};
+MODULE_DEVICE_TABLE(i2c, steelhead_avr_id);
+
+static struct i2c_driver steelhead_avr_driver = {
+	.driver = {
+		.name = "steelhead-avr",
+		.of_match_table = steelhead_avr_of_match,
+	},
+	.probe = steelhead_avr_probe,
+	.remove = steelhead_avr_remove,
+	.id_table = steelhead_avr_id,
+};
+module_i2c_driver(steelhead_avr_driver);
+
+MODULE_DESCRIPTION("Google Nexus Q / Steelhead AVR front panel input driver");
+MODULE_AUTHOR("Google, Inc.; Nexus Q revival contributors");
+MODULE_LICENSE("GPL");
