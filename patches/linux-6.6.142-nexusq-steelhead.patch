+static void omap_dma_nq_fill_audio_tone(void *buf, size_t len)
+{
+	s16 *samples = buf;
+	size_t frames = len / (2 * sizeof(*samples));
+	u32 phase = 0;
+	u32 step;
+	unsigned int rate = omap_dma_nq_audio_tone_rate;
+	unsigned int freq = omap_dma_nq_audio_tone_freq;
+	unsigned int amp = omap_dma_nq_audio_tone_amp;
+	size_t i;
+
+	if (!rate)
+		rate = 48000;
+	if (!freq)
+		freq = 440;
+	if (amp > 32767)
+		amp = 32767;
+
+	step = (u32)div_u64((u64)freq << 32, rate);
+
+	for (i = 0; i < frames; i++) {
+		s16 sample = (s16)(((s32)omap_dma_nq_sine256[phase >> 24] *
+				    (s32)amp) / 32767);
+
+		switch (omap_dma_nq_audio_tone_channel) {
+		case 1:
+			samples[(2 * i)] = 0;
+			samples[(2 * i) + 1] = sample;
+			break;
+		case 2:
+			samples[(2 * i)] = sample;
+			samples[(2 * i) + 1] = sample;
+			break;
+		default:
+			samples[(2 * i)] = sample;
+			samples[(2 * i) + 1] = 0;
+			break;
+		}
+
+		phase += step;
+	}
+}
+
+static bool omap_dma_nq_audio_tone_match(enum dma_transfer_direction dir,
+					 dma_addr_t dev_addr, unsigned es)
+{
+	if (!omap_dma_nq_audio_tone)
+		return false;
+	if (dir != DMA_MEM_TO_DEV)
+		return false;
+	if (dev_addr != (dma_addr_t)omap_dma_nq_audio_tone_dev_addr)
+		return false;
+	if (es != CSDP_DATA_TYPE_16)
+		return false;
+
+	return true;
+}
+
+static int omap_dma_nq_audio_tone_prepare(struct dma_chan *chan,
+					  struct omap_desc *d,
+					  dma_addr_t original_buf_addr,
+					  size_t buf_len, size_t period_len)
+{
+	struct device *dev = chan->device->dev;
+
+	if (!omap_dma_nq_audio_tone_match(d->dir, d->dev_addr, d->es))
+		return 0;
+	if (buf_len < 2 * sizeof(s16) || period_len > buf_len ||
+	    buf_len % (2 * sizeof(s16))) {
+		dev_err(dev,
+			"nq audio-tone invalid cyclic geometry len=%zu period=%zu\n",
+			buf_len, period_len);
+		return -EINVAL;
+	}
+
+	d->nq_audio_tone_buf = dma_alloc_coherent(dev, buf_len,
+						  &d->nq_audio_tone_dma,
+						  GFP_ATOMIC);
+	if (!d->nq_audio_tone_buf)
+		return -ENOMEM;
+
+	d->nq_audio_tone_len = buf_len;
+	d->nq_audio_tone_period_len = period_len;
+	d->nq_audio_tone_active = true;
+	omap_dma_nq_fill_audio_tone(d->nq_audio_tone_buf, buf_len);
+	d->sg[0].addr = d->nq_audio_tone_dma;
+
+	dev_info(dev,
+		 "nq audio-tone cyclic override dev=%pad original_buf=%pad tone_buf=%pad len=%zu period=%zu rate=%u freq=%u amp=%u channel=%u no_irq=%u fake_period=%u\n",
+		 &d->dev_addr, &original_buf_addr, &d->nq_audio_tone_dma,
+		 buf_len, period_len, omap_dma_nq_audio_tone_rate,
+		 omap_dma_nq_audio_tone_freq, omap_dma_nq_audio_tone_amp,
+		 omap_dma_nq_audio_tone_channel,
+		 omap_dma_nq_audio_tone_no_irq,
+		 omap_dma_nq_audio_tone_fake_period);
+
+	return 0;
+}
