diff -ruN -x .git -x build -x source -x *.o -x *.ko -x *.cmd build/patch-pristine/linux-6.6.142/arch/arm/mach-omap2/omap4-restart.c kernel/linux-6.6.142/arch/arm/mach-omap2/omap4-restart.c
--- build/patch-pristine/linux-6.6.142/arch/arm/mach-omap2/omap4-restart.c	2026-06-01 08:43:16
+++ kernel/linux-6.6.142/arch/arm/mach-omap2/omap4-restart.c	2026-06-07 09:06:50
@@ -5,9 +5,45 @@
 
 #include <linux/types.h>
 #include <linux/reboot.h>
+#include <linux/io.h>
+#include <linux/of.h>
+#include <linux/string.h>
 #include "common.h"
 #include "prm.h"
 
+#define STEELHEAD_SAR_REBOOT_REASON_OFFSET	0xa0c
+#define STEELHEAD_SAR_REBOOT_REASON_SIZE	32
+
+static void omap44xx_save_reboot_cmd(const char *cmd)
+{
+	void __iomem *sar_base;
+	const char *reason = "bootloader";
+	size_t len;
+
+	if (!of_machine_is_compatible("google,steelhead"))
+		return;
+
+	if (cmd) {
+		if (!strcmp(cmd, "normal"))
+			reason = "normal";
+		else if (!strcmp(cmd, "recovery"))
+			reason = "recovery";
+		else if (!strcmp(cmd, "recovery:wipe_data"))
+			reason = "recovery:wipe_data";
+		else if (!strcmp(cmd, "bootloader"))
+			reason = "bootloader";
+	}
+
+	sar_base = omap4_get_sar_ram_base();
+	if (!sar_base)
+		return;
+
+	len = strlen(reason);
+	memset_io(sar_base + STEELHEAD_SAR_REBOOT_REASON_OFFSET, 0,
+		  STEELHEAD_SAR_REBOOT_REASON_SIZE);
+	memcpy_toio(sar_base + STEELHEAD_SAR_REBOOT_REASON_OFFSET, reason, len);
+}
+
 /**
  * omap44xx_restart - trigger a software restart of the SoC
  * @mode: the "reboot mode", see arch/arm/kernel/{setup,process}.c
@@ -18,6 +54,6 @@
  */
 void omap44xx_restart(enum reboot_mode mode, const char *cmd)
 {
-	/* XXX Should save 'cmd' into scratchpad for use after reboot */
+	omap44xx_save_reboot_cmd(cmd);
 	omap_prm_reset_system();
 }
diff -ruN -x .git -x build -x source -x *.o -x *.ko -x *.cmd build/patch-pristine/linux-6.6.142/drivers/clk/ti/clk-44xx.c kernel/linux-6.6.142/drivers/clk/ti/clk-44xx.c
--- build/patch-pristine/linux-6.6.142/drivers/clk/ti/clk-44xx.c	2026-06-01 08:43:16
+++ kernel/linux-6.6.142/drivers/clk/ti/clk-44xx.c	2026-06-16 00:48:33
@@ -12,6 +12,7 @@
 #include <linux/clk.h>
 #include <linux/clkdev.h>
 #include <linux/clk/ti.h>
+#include <linux/of.h>
 #include <dt-bindings/clock/omap4.h>
 
 #include "clock.h"
@@ -794,7 +795,7 @@
 int __init omap4xxx_dt_clk_init(void)
 {
 	int rc;
-	struct clk *abe_dpll_ref, *abe_dpll, *sys_32k_ck, *usb_dpll;
+	struct clk *abe_dpll_ref, *abe_dpll, *abe_dpll_ref_parent, *usb_dpll;
 
 	ti_dt_clocks_register(omap44xx_clks);
 
@@ -818,8 +819,23 @@
 	 * Lock the ABE DPLL in any case to avoid issues with audio.
 	 */
 	abe_dpll_ref = clk_get_sys(NULL, "abe_dpll_refclk_mux_ck");
-	sys_32k_ck = clk_get_sys(NULL, "sys_32k_ck");
-	rc = clk_set_parent(abe_dpll_ref, sys_32k_ck);
+	if (of_machine_is_compatible("google,steelhead")) {
+		/*
+		 * Nexus Q routes McBSP2 sync from abe_24m_fclk into the
+		 * TAS5713. The vendor 3.0 kernel keeps DPLL_ABE referenced to
+		 * sys_clkin (38.4 MHz), which programs M=64, N=25 for the same
+		 * nominal 98.304 MHz lock. The generic 32 kHz reference keeps
+		 * the math exact but produces audible low-frequency modulation
+		 * on this board.
+		 */
+		abe_dpll_ref_parent = clk_get_sys(NULL, "sys_clkin_ck");
+	} else {
+		abe_dpll_ref_parent = clk_get_sys(NULL, "sys_32k_ck");
+	}
+	if (IS_ERR(abe_dpll_ref_parent))
+		rc = PTR_ERR(abe_dpll_ref_parent);
+	else
+		rc = clk_set_parent(abe_dpll_ref, abe_dpll_ref_parent);
 	abe_dpll = clk_get_sys(NULL, "dpll_abe_ck");
 	if (!rc)
 		rc = clk_set_rate(abe_dpll, OMAP4_DPLL_ABE_DEFFREQ);
