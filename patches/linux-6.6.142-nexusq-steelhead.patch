+static void omap_mcbsp_nq_pio_disable_irq(struct omap_mcbsp *mcbsp)
+{
+	if (mcbsp->irq)
+		MCBSP_WRITE(mcbsp, IRQEN,
+			    MCBSP_READ(mcbsp, IRQEN) & ~(XRDYEN | XUNDFLEN));
+}
+
+static int omap_mcbsp_nq_pio_thread_fn(void *data)
+{
+	struct omap_mcbsp *mcbsp = data;
+	unsigned long deadline =
+		jiffies + msecs_to_jiffies(omap_mcbsp_nq_pio_tone_ms + 1000);
+	unsigned long idle_loops = 0;
+	unsigned long fill_loops = 0;
+
+	while (mcbsp->nq_pio_active && !kthread_should_stop()) {
+		u16 irqst = 0;
+		u16 spcr2;
+
+		if (time_after(jiffies, deadline)) {
+			mcbsp->nq_pio_xrdy_timeouts++;
+			break;
+		}
+
+		if (mcbsp->irq) {
+			irqst = MCBSP_READ(mcbsp, IRQST);
+			if (irqst & XUNDFLEN)
+				mcbsp->nq_pio_underflow_count++;
+			if (irqst)
+				MCBSP_WRITE(mcbsp, IRQST,
+					    irqst & OMAP_MCBSP_NQ_IRQ_MASK);
+		}
+
+		if (mcbsp->pdata->buffer_size) {
+			unsigned int free_words = MCBSP_READ(mcbsp, XBUFFSTAT);
+
+			if (free_words > mcbsp->nq_pio_max_free_words)
+				mcbsp->nq_pio_max_free_words = free_words;
+		}
+
+		spcr2 = MCBSP_READ(mcbsp, SPCR2);
+		if (spcr2 & XSYNC_ERR) {
+			mcbsp->nq_pio_sync_errors++;
+			MCBSP_WRITE(mcbsp, SPCR2, MCBSP_READ_CACHE(mcbsp, SPCR2));
+		}
+
+		if (spcr2 & XRDY) {
+			if (!omap_mcbsp_nq_pio_write_next_word(mcbsp))
+				break;
+			fill_loops++;
+			idle_loops = 0;
+			if (!(fill_loops & 0x3ff))
+				cond_resched();
+			continue;
+		}
+
+		idle_loops++;
+		if (!(idle_loops & 0x1f))
+			udelay(1);
+		if (!(idle_loops & 0x3ff))
+			cond_resched();
+	}
+
+	mcbsp->nq_pio_active = false;
+	omap_mcbsp_nq_pio_disable_irq(mcbsp);
+	omap_mcbsp_nq_pio_write_word(mcbsp, 0);
+	omap_mcbsp_nq_pio_write_word(mcbsp, 0);
+	dev_info(mcbsp->dev,
+		 "nq pio xrdy tone done elapsed_ms=%llu irqs=%lu timers=%lu underflows=%lu words=%lu max_free_words=%u fill_loops=%lu idle_loops=%lu xrdy_timeouts=%lu sync_errors=%lu\n",
+		 div_u64(ktime_get_ns() - mcbsp->nq_pio_start_ns, 1000000),
+		 mcbsp->nq_pio_irq_count,
+		 mcbsp->nq_pio_timer_count,
+		 mcbsp->nq_pio_underflow_count,
+		 mcbsp->nq_pio_words_written,
+		 mcbsp->nq_pio_max_free_words,
+		 fill_loops,
+		 idle_loops,
+		 mcbsp->nq_pio_xrdy_timeouts,
+		 mcbsp->nq_pio_sync_errors);
+	omap_mcbsp_nq_pio_schedule_cleanup(mcbsp);
+
+	return 0;
+}
+
+static void omap_mcbsp_nq_pio_fill(struct omap_mcbsp *mcbsp)
+{
+	unsigned int free_words = 1;
+	unsigned int limit;
+	u16 irqst;
+
+	if (!mcbsp->nq_pio_active)
+		return;
+
+	if (mcbsp->irq) {
+		irqst = MCBSP_READ(mcbsp, IRQST);
+		if (irqst & XUNDFLEN)
+			mcbsp->nq_pio_underflow_count++;
+		MCBSP_WRITE(mcbsp, IRQST, irqst & OMAP_MCBSP_NQ_IRQ_MASK);
+	}
+
+	if (mcbsp->pdata->buffer_size)
+		free_words = MCBSP_READ(mcbsp, XBUFFSTAT);
+
+	limit = mcbsp->pdata->buffer_size ? mcbsp->pdata->buffer_size : 1;
+	free_words = min(free_words, limit);
+	if (free_words > mcbsp->nq_pio_max_free_words)
+		mcbsp->nq_pio_max_free_words = free_words;
+	if (omap_mcbsp_nq_pio_fill_words)
+		free_words = min(free_words, omap_mcbsp_nq_pio_fill_words);
+
+	while (free_words-- && mcbsp->nq_pio_active) {
+		if (!omap_mcbsp_nq_pio_write_next_word(mcbsp))
+			break;
+	}
+
+	if (!mcbsp->nq_pio_active) {
+		omap_mcbsp_nq_pio_disable_irq(mcbsp);
+		dev_info(mcbsp->dev,
+			 "nq pio tone done elapsed_ms=%llu irqs=%lu timers=%lu underflows=%lu words=%lu max_free_words=%u\n",
+			 div_u64(ktime_get_ns() - mcbsp->nq_pio_start_ns,
+				 1000000),
+			 mcbsp->nq_pio_irq_count,
+			 mcbsp->nq_pio_timer_count,
+			 mcbsp->nq_pio_underflow_count,
+			 mcbsp->nq_pio_words_written,
+			 mcbsp->nq_pio_max_free_words);
+		omap_mcbsp_nq_pio_schedule_cleanup(mcbsp);
+	}
+}
+
+static enum hrtimer_restart omap_mcbsp_nq_pio_timer(struct hrtimer *timer)
+{
+	struct omap_mcbsp *mcbsp =
+		container_of(timer, struct omap_mcbsp, nq_pio_timer);
+	unsigned int interval_us;
+
+	if (!mcbsp->nq_pio_active)
+		return HRTIMER_NORESTART;
+
+	mcbsp->nq_pio_timer_count++;
+	omap_mcbsp_nq_pio_fill(mcbsp);
+	if (!mcbsp->nq_pio_active)
+		return HRTIMER_NORESTART;
+
+	interval_us = max_t(unsigned int, omap_mcbsp_nq_pio_timer_us, 50);
+	hrtimer_forward_now(timer, ns_to_ktime((u64)interval_us * 1000));
+
+	return HRTIMER_RESTART;
+}
