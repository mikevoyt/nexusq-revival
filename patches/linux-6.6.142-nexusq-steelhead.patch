+static int tas571x_apply_raw_init(struct i2c_client *client,
+				  const struct tas571x_raw_init *seq,
+				  unsigned int num_seq)
+{
+	unsigned int i;
+	int ret;
+
+	for (i = 0; i < num_seq; i++) {
+		ret = i2c_master_send(client, seq[i].data, seq[i].len);
+		if (ret == seq[i].len)
+			continue;
+		if (ret < 0)
+			return ret;
+		return -EIO;
+	}
+
+	return 0;
+}
+
+static int tas571x_nq_apply_sys_ctrl1_override(struct tas571x_private *priv,
+					       struct i2c_client *client,
+					       const char *phase)
+{
+	int value = tas571x_nq_sys_ctrl1_override;
+	int ret;
+
+	if (value < 0)
+		return 0;
+
+	value &= 0xff;
+	ret = regmap_write(priv->regmap, TAS571X_SYS_CTRL_1_REG, value);
+	if (ret) {
+		dev_warn(&client->dev,
+			 "nq tas571x %s sys1 override 0x%02x failed: %d\n",
+			 phase, value, ret);
+		return ret;
+	}
+
+	if (tas571x_nq_dump_regs)
+		dev_info(&client->dev,
+			 "nq tas571x %s sys1 override=0x%02x\n",
+			 phase, value);
+
+	return 0;
+}
+
+static int tas571x_nq_apply_flat_dsp(struct tas571x_private *priv,
+				     struct i2c_client *client,
+				     const char *phase)
+{
+	static const long identity_biquad[] = {
+		0x00800000, 0x00000000, 0x00000000, 0x00000000, 0x00000000,
+	};
+	static const long drc_ctrl_off[] = {
+		0x00000000,
+	};
+	int ret;
+
+	if (!tas571x_nq_flat_dsp)
+		return 0;
+
+	ret = tas571x_reg_write_multiword(client, 0x29, identity_biquad,
+					  ARRAY_SIZE(identity_biquad));
+	if (ret)
+		goto fail;
+	ret = tas571x_reg_write_multiword(client, 0x2a, identity_biquad,
+					  ARRAY_SIZE(identity_biquad));
+	if (ret)
+		goto fail;
+	ret = tas571x_reg_write_multiword(client, 0x46, drc_ctrl_off,
+					  ARRAY_SIZE(drc_ctrl_off));
+	if (ret)
+		goto fail;
+
+	if (tas571x_nq_dump_regs)
+		dev_info(&client->dev, "nq tas571x %s flat-dsp applied\n",
+			 phase);
+
+	return 0;
+
+fail:
+	dev_warn(&client->dev, "nq tas571x %s flat-dsp failed: %d\n",
+		 phase, ret);
+	return ret;
+}
