+static void omap_dma_nq_dump_irq(struct omap_chan *c, struct omap_desc *d,
+				 u16 status)
+{
+	struct omap_dmadev *od = to_omap_dma_dev(c->vc.chan.device);
+	unsigned int count;
+	u32 irqenable_l1 = 0;
+	u32 irqstatus_l1 = 0;
+	bool error;
+
+	if (!omap_dma_nq_dump_cyclic || !omap_dma_nq_dump_irq_limit ||
+	    !c->cyclic || !d)
