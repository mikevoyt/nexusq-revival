+
+static void omap_dma_nq_progress_dump_trace(struct omap_chan *c)
+{
+	unsigned int i;
+
+	if (!c->nq_progress_trace || !c->nq_progress_trace_count)
+		return;
+
+	for (i = 0; i < c->nq_progress_trace_count; i += 16) {
+		char line[768];
+		unsigned int end = min_t(unsigned int,
+					 c->nq_progress_trace_count, i + 16);
+		unsigned int j;
+		int len = 0;
+
+		for (j = i; j < end; j++) {
+			const struct omap_dma_nq_progress_sample *s =
+				&c->nq_progress_trace[j];
+
+			len += scnprintf(line + len, sizeof(line) - len,
+					 "%s%u/%u/%u",
+					 j == i ? "" : ",",
+					 s->elapsed_us, s->delta, s->pos);
+		}
+
+		dev_info(c->vc.chan.device->dev,
+			 "nq progress trace sig=%u channel=%d first=%u count=%u dropped=%u data=%s\n",
+			 c->dma_sig, c->dma_ch, i, end - i,
+			 c->nq_progress_trace_dropped, line);
+	}
+}
