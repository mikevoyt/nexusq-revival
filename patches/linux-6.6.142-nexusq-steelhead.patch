+static void tas571x_legacy_mclk_disable(struct tas571x_private *priv)
+{
+	if (!IS_ERR(priv->mclk) && priv->legacy_mclk_enabled) {
+		clk_disable_unprepare(priv->mclk);
+		priv->legacy_mclk_enabled = false;
+	}
+}
+
+static void tas571x_bias_mclk_disable(struct tas571x_private *priv)
+{
+	if (!IS_ERR(priv->mclk) && priv->bias_mclk_enabled) {
+		clk_disable_unprepare(priv->mclk);
+		priv->bias_mclk_enabled = false;
+	}
+}
+
+static int tas571x_legacy_power_up(struct tas571x_private *priv,
+				   struct i2c_client *client,
+				   bool keep_mclk_enabled)
+{
+	struct device *dev = &client->dev;
+	unsigned int dev_id;
+	bool mclk_enabled_this_call = false;
+	int ret;
+
+	if (tas571x_nq_cycle_mclk_on_legacy_reset &&
+	    !IS_ERR(priv->mclk) && priv->legacy_mclk_enabled)
+		tas571x_legacy_mclk_disable(priv);
+
+	if (priv->pdn_gpio)
+		gpiod_set_value(priv->pdn_gpio, 1);
+	if (priv->reset_gpio)
+		gpiod_set_value(priv->reset_gpio, 1);
+	usleep_range(TAS571X_STEELHEAD_PDN_ASSERT_DELAY_US,
+		     TAS571X_STEELHEAD_PDN_ASSERT_DELAY_US + 1000);
+
+	if (!IS_ERR(priv->mclk) && !priv->legacy_mclk_enabled) {
+		ret = clk_prepare_enable(priv->mclk);
+		if (ret) {
+			dev_err(dev, "Failed to enable master clock: %d\n", ret);
+			return ret;
+		}
+		mclk_enabled_this_call = true;
+	}
+
+	if (priv->pdn_gpio)
+		gpiod_set_value(priv->pdn_gpio, 0);
+	usleep_range(TAS571X_STEELHEAD_POST_PDN_DELAY_US,
+		     TAS571X_STEELHEAD_POST_PDN_DELAY_US + 100);
+
+	if (priv->reset_gpio)
+		gpiod_set_value(priv->reset_gpio, 0);
+	usleep_range(TAS571X_STEELHEAD_POST_RESET_DELAY_US,
+		     TAS571X_STEELHEAD_POST_RESET_DELAY_US + 6500);
+
+	ret = regmap_read(priv->regmap, TAS571X_DEV_ID_REG, &dev_id);
+	if (ret) {
+		dev_err(dev, "Failed to read device ID after reset: %d\n", ret);
+		goto disable_mclk;
+	}
+
+	ret = regmap_write(priv->regmap, TAS571X_OSC_TRIM_REG, 0);
+	if (ret) {
+		dev_err(dev, "Failed to trim oscillator: %d\n", ret);
+		goto disable_mclk;
+	}
+
+	usleep_range(TAS571X_STEELHEAD_POST_TRIM_DELAY_US,
+		     TAS571X_STEELHEAD_POST_TRIM_DELAY_US + 10000);
+
+	ret = tas571x_apply_raw_init(client, priv->chip->init_sequence,
+				     priv->chip->num_init_sequence);
+	if (ret) {
+		dev_err(dev, "Failed to apply init sequence: %d\n", ret);
+		goto disable_mclk;
+	}
+
+	ret = tas571x_nq_apply_sys_ctrl1_override(priv, client,
+						  "legacy-power-up");
+	if (ret)
+		goto disable_mclk;
+
+	ret = tas571x_nq_apply_flat_dsp(priv, client, "legacy-power-up");
+	if (ret)
+		goto disable_mclk;
+
+	ret = regmap_write(priv->regmap, TAS571X_SYS_CTRL_2_REG, 0);
+	if (ret) {
+		dev_err(dev, "Failed to exit shutdown: %d\n", ret);
+		goto disable_mclk;
+	}
+
+	usleep_range(priv->chip->shutdown_delay_us,
+		     priv->chip->shutdown_delay_us + 1000);
+
+	tas571x_nq_dump_registers(priv, client, "legacy-power-up");
+
+	disable_mclk:
+	if (!ret)
+		priv->legacy_powered_down = false;
+
+	if (mclk_enabled_this_call && (ret || !keep_mclk_enabled)) {
+		clk_disable_unprepare(priv->mclk);
+	} else if (!ret && keep_mclk_enabled && mclk_enabled_this_call) {
+		priv->legacy_mclk_enabled = true;
+	} else if (!keep_mclk_enabled && priv->legacy_mclk_enabled) {
+		tas571x_legacy_mclk_disable(priv);
+	} else if (ret && priv->legacy_mclk_enabled) {
+		tas571x_legacy_mclk_disable(priv);
+	}
+
+	return ret;
+}
+
+static int tas571x_legacy_power_down(struct tas571x_private *priv,
+				     struct i2c_client *client)
+{
+	struct device *dev = &client->dev;
+	unsigned int delay_us = priv->chip->shutdown_delay_us;
+	int ret;
+
+	if (tas571x_nq_dump_regs)
+		tas571x_nq_dump_registers(priv, client,
+					  "pre-legacy-power-down");
+
+	ret = regmap_write(priv->regmap, TAS571X_SYS_CTRL_2_REG,
+			   TAS571X_SYS_CTRL_2_SDN_MASK);
+	if (ret) {
+		dev_warn(dev,
+			 "Failed to enter TAS5713 shutdown before power-down: %d\n",
+			 ret);
+		if (priv->pdn_gpio)
+			gpiod_set_value(priv->pdn_gpio, 1);
+		usleep_range(TAS571X_STEELHEAD_PDN_ASSERT_DELAY_US,
+			     TAS571X_STEELHEAD_PDN_ASSERT_DELAY_US + 1000);
+	} else if (delay_us) {
+		usleep_range(delay_us, delay_us + 1000);
+		if (priv->pdn_gpio)
+			gpiod_set_value(priv->pdn_gpio, 1);
+	} else {
+		usleep_range(1000, 2000);
+		if (priv->pdn_gpio)
+			gpiod_set_value(priv->pdn_gpio, 1);
+	}
+
+	if (priv->reset_gpio)
+		gpiod_set_value(priv->reset_gpio, 1);
+
+	tas571x_bias_mclk_disable(priv);
+	tas571x_legacy_mclk_disable(priv);
+	priv->legacy_powered_down = true;
+
+	if (tas571x_nq_dump_regs)
+		dev_info(dev,
+			 "nq tas571x legacy-power-down ret=%d pdn=%d reset=%d\n",
+			 ret, !!priv->pdn_gpio, !!priv->reset_gpio);
+
+	return 0;
+}
+
+static unsigned int tas571x_legacy_cached_reg(struct tas571x_private *priv,
+					      unsigned int reg,
+					      unsigned int fallback)
+{
+	unsigned int val = fallback;
+	int ret;
+
+	if (!priv->legacy_powered_down) {
+		ret = regmap_read(priv->regmap, reg, &val);
+		if (!ret)
+			return val;
+	}
+
+	regcache_cache_only(priv->regmap, true);
+	ret = regmap_read(priv->regmap, reg, &val);
+	regcache_cache_only(priv->regmap, false);
+	if (ret)
+		val = fallback;
+
+	return val;
+}
+
+static int tas571x_legacy_stream_reinit(struct tas571x_private *priv,
+					struct i2c_client *client,
+					bool keep_mclk_enabled)
+{
+	unsigned int mvol, ch1_vol, ch2_vol, soft_mute;
+	unsigned int sdi;
+	int ret;
+
+	mvol = tas571x_legacy_cached_reg(priv, TAS571X_MVOL_REG, 0xff);
+	ch1_vol = tas571x_legacy_cached_reg(priv, TAS571X_CH1_VOL_REG, 0x30);
+	ch2_vol = tas571x_legacy_cached_reg(priv, TAS571X_CH2_VOL_REG, 0x30);
+	soft_mute = tas571x_legacy_cached_reg(priv, TAS571X_SOFT_MUTE_REG, 0);
+
+	ret = tas571x_legacy_power_up(priv, client, keep_mclk_enabled);
+	if (ret)
+		return ret;
+
+	if (priv->sdi_format_valid) {
+		ret = tas571x_reg_read(client, TAS571X_SDI_REG, &sdi);
+		if (ret)
+			sdi = priv->sdi_format;
+		else
+			sdi = (sdi & ~TAS571X_SDI_FMT_MASK) |
+			      priv->sdi_format;
+
+		ret = regmap_write(priv->regmap, TAS571X_SDI_REG, sdi);
+		if (ret)
+			return ret;
+	}
+
+	ret = regmap_write(priv->regmap, TAS571X_MVOL_REG, mvol);
+	if (ret)
+		return ret;
+	ret = regmap_write(priv->regmap, TAS571X_CH1_VOL_REG, ch1_vol);
+	if (ret)
+		return ret;
+	ret = regmap_write(priv->regmap, TAS571X_CH2_VOL_REG, ch2_vol);
+	if (ret)
+		return ret;
+	ret = regmap_write(priv->regmap, TAS571X_SOFT_MUTE_REG, soft_mute);
+	if (ret)
+		return ret;
+
+	return regmap_write(priv->regmap, TAS571X_ERR_STATUS_REG, 0);
+}
