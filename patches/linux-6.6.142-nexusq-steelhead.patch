+static int omap_dma_get_lch_exact(struct omap_dmadev *od, int channel, int *lch)
+{
+	if (channel < 0 || channel >= od->lch_count) {
+		dev_info(od->ddev.dev,
+			 "nq force-lch invalid channel=%d lch_count=%d\n",
+			 channel, od->lch_count);
+		*lch = -EINVAL;
+		return -EINVAL;
+	}
+
+	mutex_lock(&od->lch_lock);
+	dev_info(od->ddev.dev,
+		 "nq force-lch try channel=%d reserved_bit=%d map=%px\n",
+		 channel, test_bit(channel, od->lch_bitmap),
+		 od->lch_map[channel]);
+	if (od->lch_map[channel])
+		goto out_busy;
+
+	/*
+	 * The default DT path marks channels 0 and 1 reserved when no explicit
+	 * channel mask is present. The old Nexus Q 3.0 audio path used channel
+	 * 0 successfully, so this diagnostic is allowed to take a reserved-but
+	 * currently unassigned channel for a controlled A/B test.
+	 */
+	set_bit(channel, od->lch_bitmap);
+	mutex_unlock(&od->lch_lock);
+
+	*lch = channel;
+	return 0;
+
+out_busy:
+	dev_info(od->ddev.dev,
+		 "nq force-lch busy channel=%d reserved_bit=%d map=%px busy_sig=%u\n",
+		 channel, test_bit(channel, od->lch_bitmap),
+		 od->lch_map[channel],
+		 od->lch_map[channel] ? od->lch_map[channel]->dma_sig : 0);
+	mutex_unlock(&od->lch_lock);
+	*lch = -EINVAL;
+	return -EBUSY;
+}
