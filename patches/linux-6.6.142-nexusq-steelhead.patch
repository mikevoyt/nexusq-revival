+static unsigned int steelhead_tas5713_dai_fmt(unsigned int provider)
+{
+	return steelhead_tas5713_dai_format |
+	       steelhead_tas5713_dai_inversion | provider;
+}
+
+struct steelhead_tas5713 {
+	struct snd_soc_card card;
+	struct clk *codec_mclk;
+	struct clk *codec_src;
+	struct clk *codec_src_parent;
+	struct clk *mcbsp_clk;
+	struct clk *mcbsp_parent;
+	bool mcbsp_clk_hw_params_enabled;
+};
+
+static const struct snd_soc_dapm_widget steelhead_tas5713_widgets[] = {
+	SND_SOC_DAPM_SPK("Internal Speaker", NULL),
+};
+
+static const struct snd_soc_dapm_route steelhead_tas5713_routes[] = {
+	{ "Internal Speaker", NULL, "OUT_A" },
+	{ "Internal Speaker", NULL, "OUT_B" },
+	{ "Internal Speaker", NULL, "OUT_C" },
+	{ "Internal Speaker", NULL, "OUT_D" },
+};
+
+static void steelhead_tas5713_clk_put(void *data)
+{
+	clk_put(data);
+}
+
+static struct clk *steelhead_tas5713_get_legacy_clk(struct device *dev,
+						    const char *name)
+{
+	struct clk *clk;
+	int ret;
+
+	clk = clk_get(NULL, name);
+	if (IS_ERR(clk)) {
+		dev_warn(dev, "failed to get %s: %ld\n", name, PTR_ERR(clk));
+		return NULL;
+	}
+
+	ret = devm_add_action_or_reset(dev, steelhead_tas5713_clk_put, clk);
+	if (ret)
+		return ERR_PTR(ret);
+
+	return clk;
+}
+
+static int steelhead_tas5713_startup(struct snd_pcm_substream *substream)
+{
+	struct snd_soc_pcm_runtime *rtd = asoc_substream_to_rtd(substream);
+	struct steelhead_tas5713 *priv = snd_soc_card_get_drvdata(rtd->card);
+	int ret;
+
+	if (substream->stream == SNDRV_PCM_STREAM_PLAYBACK) {
+		if (steelhead_tas5713_legacy_s16_only) {
+			ret = snd_pcm_hw_constraint_mask64(substream->runtime,
+							   SNDRV_PCM_HW_PARAM_FORMAT,
+							   SNDRV_PCM_FMTBIT_S16_LE);
+			if (ret)
+				return ret;
+		}
+
+		if (steelhead_tas5713_period_size && steelhead_tas5713_periods) {
+			unsigned int buffer_size;
+
+			ret = snd_pcm_hw_constraint_single(substream->runtime,
+							   SNDRV_PCM_HW_PARAM_PERIOD_SIZE,
+							   steelhead_tas5713_period_size);
+			if (ret)
+				return ret;
+
+			ret = snd_pcm_hw_constraint_single(substream->runtime,
+							   SNDRV_PCM_HW_PARAM_PERIODS,
+							   steelhead_tas5713_periods);
+			if (ret)
+				return ret;
+
+			buffer_size = steelhead_tas5713_period_size *
+				      steelhead_tas5713_periods;
+			ret = snd_pcm_hw_constraint_single(substream->runtime,
+							   SNDRV_PCM_HW_PARAM_BUFFER_SIZE,
+							   buffer_size);
+			if (ret)
+				return ret;
+		}
+	}
+
+	if (steelhead_tas5713_codec_mclk_startup &&
+	    !IS_ERR_OR_NULL(priv->codec_mclk)) {
+		ret = clk_prepare_enable(priv->codec_mclk);
+		if (ret)
+			return ret;
+	}
+
+		if (steelhead_tas5713_mcbsp_clk_startup &&
+		    !IS_ERR_OR_NULL(priv->mcbsp_clk)) {
+			ret = clk_prepare_enable(priv->mcbsp_clk);
+			if (ret) {
+				if (steelhead_tas5713_codec_mclk_startup)
+					clk_disable_unprepare(priv->codec_mclk);
+				return ret;
+			}
+		}
+
+	if (steelhead_tas5713_nq_dump)
+		dev_info(rtd->card->dev,
+			 "nq steelhead startup codec-mclk=%lu mcbsp=%lu\n",
+			 priv->codec_mclk ? clk_get_rate(priv->codec_mclk) : 0,
+			 priv->mcbsp_clk ? clk_get_rate(priv->mcbsp_clk) : 0);
+
+	return 0;
+}
+
+static void steelhead_tas5713_shutdown(struct snd_pcm_substream *substream)
+{
+	struct snd_soc_pcm_runtime *rtd = asoc_substream_to_rtd(substream);
+	struct steelhead_tas5713 *priv = snd_soc_card_get_drvdata(rtd->card);
+
+	if (steelhead_tas5713_nq_dump)
+		dev_info(rtd->card->dev,
+			 "nq steelhead shutdown codec-mclk=%lu mcbsp=%lu\n",
+			 priv->codec_mclk ? clk_get_rate(priv->codec_mclk) : 0,
+			 priv->mcbsp_clk ? clk_get_rate(priv->mcbsp_clk) : 0);
+
+	if (priv->mcbsp_clk_hw_params_enabled) {
+		clk_disable_unprepare(priv->mcbsp_clk);
+		priv->mcbsp_clk_hw_params_enabled = false;
+	}
+	if (steelhead_tas5713_mcbsp_clk_startup)
+		clk_disable_unprepare(priv->mcbsp_clk);
+	if (steelhead_tas5713_codec_mclk_startup)
+		clk_disable_unprepare(priv->codec_mclk);
+}
+
+static int steelhead_tas5713_hw_free(struct snd_pcm_substream *substream)
+{
+	struct snd_soc_pcm_runtime *rtd = asoc_substream_to_rtd(substream);
+	struct steelhead_tas5713 *priv = snd_soc_card_get_drvdata(rtd->card);
+
+	if (substream->stream != SNDRV_PCM_STREAM_PLAYBACK)
+		return 0;
+
+	if (priv->mcbsp_clk_hw_params_enabled) {
+		if (steelhead_tas5713_nq_dump)
+			dev_info(rtd->card->dev,
+				 "nq steelhead hw_free disable mcbsp hw_params clock\n");
+		clk_disable_unprepare(priv->mcbsp_clk);
+		priv->mcbsp_clk_hw_params_enabled = false;
+	}
+
+	return 0;
+}
+
+static int steelhead_tas5713_hw_params(struct snd_pcm_substream *substream,
+				       struct snd_pcm_hw_params *params)
+{
+	struct snd_soc_pcm_runtime *rtd = asoc_substream_to_rtd(substream);
+	struct snd_soc_dai *codec_dai = asoc_rtd_to_codec(rtd, 0);
+	struct snd_soc_dai *cpu_dai = asoc_rtd_to_cpu(rtd, 0);
+	struct snd_soc_card *card = rtd->card;
+	struct steelhead_tas5713 *priv = snd_soc_card_get_drvdata(card);
+	unsigned long clk_rate, target_rate, mclk_rate;
+	unsigned int bclk_fs;
+	unsigned int cpu_fmt, codec_fmt;
+	int clk_div;
+	int ret;
+
+	if (substream->stream != SNDRV_PCM_STREAM_PLAYBACK)
+		return -EINVAL;
+
+	if (steelhead_tas5713_mcbsp_clk_hw_params &&
+	    !IS_ERR_OR_NULL(priv->mcbsp_clk) &&
+	    !priv->mcbsp_clk_hw_params_enabled) {
+		ret = clk_prepare_enable(priv->mcbsp_clk);
+		if (ret)
+			return ret;
+		priv->mcbsp_clk_hw_params_enabled = true;
+	}
+
+	if (steelhead_tas5713_legacy_s16_only &&
+	    params_format(params) != SNDRV_PCM_FORMAT_S16_LE) {
+		dev_err(card->dev,
+			"rejecting non-legacy TAS5713 format %d while S16-only mode is enabled\n",
+			params_format(params));
+		ret = -EINVAL;
+		goto err_disable_mcbsp_hw_params_clk;
+	}
+
+	mclk_rate = params_rate(params) * STEELHEAD_TAS5713_MCLK_FS;
+	if (!IS_ERR_OR_NULL(priv->codec_mclk)) {
+		ret = clk_set_rate(priv->codec_mclk, mclk_rate);
+		if (ret)
+			goto err_disable_mcbsp_hw_params_clk;
+
+		mclk_rate = clk_get_rate(priv->codec_mclk);
+		if (mclk_rate != params_rate(params) * STEELHEAD_TAS5713_MCLK_FS)
+			dev_warn(card->dev, "codec mclk is %lu for rate %u\n",
+				 mclk_rate, params_rate(params));
+	}
+
+	cpu_fmt = steelhead_tas5713_dai_fmt(SND_SOC_DAIFMT_BP_FP);
+	codec_fmt = steelhead_tas5713_dai_fmt(SND_SOC_DAIFMT_BC_FC);
+
+	ret = snd_soc_dai_set_fmt(cpu_dai, cpu_fmt);
+	if (ret)
+		goto err_disable_mcbsp_hw_params_clk;
+
+	clk_rate = clk_get_rate(priv->mcbsp_clk);
+	bclk_fs = steelhead_tas5713_bclk_fs_override;
+	if (!bclk_fs)
+		bclk_fs = params_physical_width(params) * params_channels(params);
+	target_rate = params_rate(params) * bclk_fs;
+	clk_div = DIV_ROUND_CLOSEST(clk_rate, target_rate);
+
+	if (!clk_div || clk_div > 256 ||
+	    clk_rate / clk_div != target_rate ||
+	    clk_rate % target_rate) {
+		dev_err(card->dev,
+			"cannot derive bclk: parent=%lu target=%lu rate=%u div=%d\n",
+			clk_rate, target_rate, params_rate(params), clk_div);
+		ret = -EINVAL;
+		goto err_disable_mcbsp_hw_params_clk;
+	}
+
+	ret = snd_soc_dai_set_sysclk(cpu_dai, OMAP_MCBSP_SYSCLK_CLKS_FCLK,
+				     clk_rate, SND_SOC_CLOCK_IN);
+	if (ret)
+		goto err_disable_mcbsp_hw_params_clk;
+
+	ret = snd_soc_dai_set_clkdiv(cpu_dai, OMAP_MCBSP_CLKGDV, clk_div);
+	if (ret)
+		goto err_disable_mcbsp_hw_params_clk;
+
+	if (!steelhead_tas5713_skip_codec_fmt) {
+		ret = snd_soc_dai_set_fmt(codec_dai, codec_fmt);
+		if (ret && ret != -ENOTSUPP)
+			goto err_disable_mcbsp_hw_params_clk;
+	}
+
+	if (steelhead_tas5713_nq_dump)
+		dev_info(card->dev,
+			 "nq steelhead hw_params format=%s inversion=%s legacy_s16_only=%d rate=%u width=%d physical_width=%d channels=%u mclk=%lu mcbsp=%lu bclk_fs=%u bclk_override=%u bclk=%lu div=%d cpu_fmt=0x%x codec_fmt=0x%x skip_codec_fmt=%d mcbsp_clk_hw_params=%d\n",
+			 steelhead_tas5713_dai_format_name,
+			 steelhead_tas5713_dai_inversion_name,
+			 steelhead_tas5713_legacy_s16_only,
+			 params_rate(params), params_width(params),
+			 params_physical_width(params), params_channels(params),
+			 mclk_rate, clk_rate, bclk_fs,
+			 steelhead_tas5713_bclk_fs_override, target_rate,
+			 clk_div, cpu_fmt, codec_fmt,
+			 steelhead_tas5713_skip_codec_fmt,
+			 priv->mcbsp_clk_hw_params_enabled);
+
+	return 0;
+
+err_disable_mcbsp_hw_params_clk:
+	if (priv->mcbsp_clk_hw_params_enabled) {
+		clk_disable_unprepare(priv->mcbsp_clk);
+		priv->mcbsp_clk_hw_params_enabled = false;
+	}
+
+	return ret;
+}
+
+static const char *steelhead_tas5713_trigger_cmd_name(int cmd)
+{
+	switch (cmd) {
+	case SNDRV_PCM_TRIGGER_START:
+		return "START";
+	case SNDRV_PCM_TRIGGER_STOP:
+		return "STOP";
+	case SNDRV_PCM_TRIGGER_RESUME:
+		return "RESUME";
+	case SNDRV_PCM_TRIGGER_SUSPEND:
+		return "SUSPEND";
+	case SNDRV_PCM_TRIGGER_PAUSE_RELEASE:
+		return "PAUSE_RELEASE";
+	case SNDRV_PCM_TRIGGER_PAUSE_PUSH:
+		return "PAUSE_PUSH";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+static int steelhead_tas5713_trigger(struct snd_pcm_substream *substream,
+				     int cmd)
+{
+	struct snd_soc_pcm_runtime *rtd = asoc_substream_to_rtd(substream);
+	struct snd_soc_dai *codec_dai = asoc_rtd_to_codec(rtd, 0);
+	int mute;
+
+	if (!steelhead_tas5713_codec_power_first ||
+	    substream->stream != SNDRV_PCM_STREAM_PLAYBACK)
+		return 0;
+
+	switch (cmd) {
+	case SNDRV_PCM_TRIGGER_START:
+	case SNDRV_PCM_TRIGGER_RESUME:
+	case SNDRV_PCM_TRIGGER_PAUSE_RELEASE:
+		mute = 0;
+		break;
+	case SNDRV_PCM_TRIGGER_STOP:
+	case SNDRV_PCM_TRIGGER_SUSPEND:
+	case SNDRV_PCM_TRIGGER_PAUSE_PUSH:
+		mute = 1;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (steelhead_tas5713_nq_dump)
+		dev_info(rtd->card->dev,
+			 "nq steelhead trigger cmd=%s codec_power_first=1 mute=%d\n",
+			 steelhead_tas5713_trigger_cmd_name(cmd), mute);
+
+	return snd_soc_dai_digital_mute(codec_dai, mute, substream->stream);
+}
+
+static const struct snd_soc_ops steelhead_tas5713_ops = {
+	.startup = steelhead_tas5713_startup,
+	.shutdown = steelhead_tas5713_shutdown,
+	.hw_params = steelhead_tas5713_hw_params,
+	.hw_free = steelhead_tas5713_hw_free,
+	.trigger = steelhead_tas5713_trigger,
+};
