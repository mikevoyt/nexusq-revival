+	DAILINK_COMP_ARRAY(COMP_EMPTY()),
+	DAILINK_COMP_ARRAY(COMP_CODEC(NULL, "tas571x-hifi")),
+	DAILINK_COMP_ARRAY(COMP_EMPTY()));
+
+static struct snd_soc_dai_link steelhead_tas5713_link = {
+	.name = "TAS5713",
+	.stream_name = "TAS5713",
+	.dai_fmt = SND_SOC_DAIFMT_I2S |
+		   SND_SOC_DAIFMT_NB_NF |
+		   SND_SOC_DAIFMT_CBC_CFC,
+	.ops = &steelhead_tas5713_ops,
+	/*
+	 * Steelhead's TAS5713 compatibility path can do I2C/reset-delay work from
+	 * codec mute/unmute when testing old trigger-time power sequencing.
+	 */
+	.nonatomic = 1,
+	SND_SOC_DAILINK_REG(steelhead_tas5713),
+};
