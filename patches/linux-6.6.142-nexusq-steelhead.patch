+static void omap_mcbsp_nq_pio_start(struct omap_mcbsp *mcbsp)
+{
+	unsigned int threshold;
+	unsigned int rate = mcbsp->nq_playback_rate;
+	unsigned int interval_us;
+
+	if (!omap_mcbsp_nq_pio_tone_ms)
+		return;
+
+	if (mcbsp->nq_playback_wlen != 16 || mcbsp->nq_playback_channels != 2 ||
+	    !rate || !mcbsp->irq) {
+		dev_warn(mcbsp->dev,
+			 "nq pio tone skipped rate=%u channels=%u wlen=%u irq=%d\n",
+			 rate, mcbsp->nq_playback_channels,
+			 mcbsp->nq_playback_wlen, mcbsp->irq);
+		return;
+	}
+
+	mcbsp->nq_pio_active = true;
+	mcbsp->nq_pio_phase = 0;
+	mcbsp->nq_pio_step = div_u64((u64)omap_mcbsp_nq_pio_tone_freq << 32,
+				     rate);
+	mcbsp->nq_pio_word_in_frame = 0;
+	mcbsp->nq_pio_remaining_frames =
+		div_u64((u64)rate * omap_mcbsp_nq_pio_tone_ms + 999, 1000);
+	mcbsp->nq_pio_start_ns = ktime_get_ns();
+	mcbsp->nq_pio_irq_count = 0;
+	mcbsp->nq_pio_timer_count = 0;
+	mcbsp->nq_pio_underflow_count = 0;
+	mcbsp->nq_pio_words_written = 0;
+	mcbsp->nq_pio_max_free_words = 0;
+	mcbsp->nq_pio_xrdy_timeouts = 0;
+	mcbsp->nq_pio_sync_errors = 0;
+	mcbsp->nq_pio_stop_deferred = false;
+	mcbsp->nq_pio_shutdown_deferred = false;
+	mcbsp->nq_pio_thread = NULL;
+	hrtimer_cancel(&mcbsp->nq_pio_timer);
+
+	if (mcbsp->pdata->buffer_size) {
+		threshold = clamp_t(unsigned int, omap_mcbsp_nq_pio_threshold,
+				    1, mcbsp->max_tx_thres);
+		omap_mcbsp_set_tx_threshold(mcbsp, threshold);
+	}
+
+	MCBSP_WRITE(mcbsp, XCCR, MCBSP_READ(mcbsp, XCCR) & ~XDMAEN);
+	MCBSP_WRITE(mcbsp, IRQST, OMAP_MCBSP_NQ_IRQ_MASK);
+	if (omap_mcbsp_nq_pio_xrdy_poll)
+		omap_mcbsp_nq_pio_disable_irq(mcbsp);
+	else if (omap_mcbsp_nq_pio_irq)
+		MCBSP_WRITE(mcbsp, IRQEN,
+			    (MCBSP_READ(mcbsp, IRQEN) | XRDYEN | XUNDFLEN) &
+			    OMAP_MCBSP_NQ_IRQ_MASK);
+	else
+		omap_mcbsp_nq_pio_disable_irq(mcbsp);
+
+	interval_us = max_t(unsigned int, omap_mcbsp_nq_pio_timer_us, 50);
+	dev_info(mcbsp->dev,
+		 "nq pio tone start rate=%u freq=%u amp=%u ms=%u step=0x%08x threshold=%u timer_us=%u fill_words=%u irq=%d reg_size=%u\n",
+		 rate, omap_mcbsp_nq_pio_tone_freq,
+		 min_t(unsigned int, omap_mcbsp_nq_pio_tone_amp, 32767),
+		 omap_mcbsp_nq_pio_tone_ms, mcbsp->nq_pio_step,
+		 mcbsp->pdata->buffer_size ?
+		 clamp_t(unsigned int, omap_mcbsp_nq_pio_threshold, 1,
+			 mcbsp->max_tx_thres) : 0,
+		 interval_us, omap_mcbsp_nq_pio_fill_words,
+		 omap_mcbsp_nq_pio_irq,
+		 mcbsp->pdata->reg_size);
+
+	if (omap_mcbsp_nq_pio_xrdy_poll) {
+		omap_mcbsp_nq_pio_fill(mcbsp);
+		mcbsp->nq_pio_thread =
+			kthread_run(omap_mcbsp_nq_pio_thread_fn, mcbsp,
+				    "nq-mcbsp-pio/%d", mcbsp->id);
+		if (IS_ERR(mcbsp->nq_pio_thread)) {
+			dev_err(mcbsp->dev,
+				"nq pio xrdy thread start failed: %ld\n",
+				PTR_ERR(mcbsp->nq_pio_thread));
+			mcbsp->nq_pio_thread = NULL;
+			mcbsp->nq_pio_active = false;
+		}
+		return;
+	}
+
+	omap_mcbsp_nq_pio_fill(mcbsp);
+	hrtimer_start(&mcbsp->nq_pio_timer,
+		      ns_to_ktime((u64)interval_us * 1000),
+		      HRTIMER_MODE_REL);
+}
+
+static void omap_mcbsp_nq_pio_stop(struct omap_mcbsp *mcbsp)
+{
+	if (!omap_mcbsp_nq_pio_tone_ms && !mcbsp->nq_pio_active)
+		return;
+
+	mcbsp->nq_pio_active = false;
+	if (mcbsp->nq_pio_thread && mcbsp->nq_pio_thread != current) {
+		kthread_stop(mcbsp->nq_pio_thread);
+		mcbsp->nq_pio_thread = NULL;
+	}
+	hrtimer_cancel(&mcbsp->nq_pio_timer);
+	omap_mcbsp_nq_pio_disable_irq(mcbsp);
+	omap_mcbsp_nq_pio_write_word(mcbsp, 0);
+	omap_mcbsp_nq_pio_write_word(mcbsp, 0);
+	omap_mcbsp_nq_pio_schedule_cleanup(mcbsp);
+}
+
+static void omap_mcbsp_nq_fifo_trace_free(struct omap_mcbsp *mcbsp)
+{
+	kfree(mcbsp->nq_fifo_trace);
+	mcbsp->nq_fifo_trace = NULL;
+	mcbsp->nq_fifo_trace_capacity = 0;
+	mcbsp->nq_fifo_trace_count = 0;
+	mcbsp->nq_fifo_trace_dropped = 0;
+	mcbsp->nq_fifo_trace_start_ns = 0;
+}
+
+static void omap_mcbsp_nq_fifo_trace_dump(struct omap_mcbsp *mcbsp)
+{
+	unsigned int i;
+
+	if (!mcbsp->nq_fifo_trace || !mcbsp->nq_fifo_trace_count)
+		return;
+
+	for (i = 0; i < mcbsp->nq_fifo_trace_count; i += 12) {
+		char line[768];
+		unsigned int end = min_t(unsigned int,
+					 mcbsp->nq_fifo_trace_count, i + 12);
+		unsigned int j;
+		int len = 0;
+
+		for (j = i; j < end; j++) {
+			const struct omap_mcbsp_nq_fifo_trace_sample *s =
+				&mcbsp->nq_fifo_trace[j];
+
+			len += scnprintf(line + len, sizeof(line) - len,
+					 "%s%u/0x%04x/0x%04x/0x%04x/0x%04x",
+					 j == i ? "" : ",",
+					 s->elapsed_us, s->xbuffstat,
+					 s->irqst, s->spcr2, s->xccr);
+		}
+
+		dev_info(mcbsp->dev,
+			 "nq fifo trace first=%u count=%u dropped=%u data=%s\n",
+			 i, end - i, mcbsp->nq_fifo_trace_dropped, line);
+	}
+}
+
+static void omap_mcbsp_nq_fifo_poll_sample(struct omap_mcbsp *mcbsp)
+{
+	u16 irqst = 0;
+	u16 spcr2;
+	u16 xbuffstat;
+	u16 xccr = 0;
+
+	if (!mcbsp->nq_fifo_poll_active)
+		return;
+
+	xbuffstat = MCBSP_READ(mcbsp, XBUFFSTAT);
+	spcr2 = MCBSP_READ(mcbsp, SPCR2);
+	if (mcbsp->irq)
+		irqst = MCBSP_READ(mcbsp, IRQST);
+	if (mcbsp->pdata->has_ccr)
+		xccr = MCBSP_READ(mcbsp, XCCR);
+
+	if (mcbsp->nq_fifo_trace) {
+		if (mcbsp->nq_fifo_trace_count <
+		    mcbsp->nq_fifo_trace_capacity) {
+			struct omap_mcbsp_nq_fifo_trace_sample *s =
+				&mcbsp->nq_fifo_trace[mcbsp->nq_fifo_trace_count++];
+			u64 elapsed_us;
+
+			elapsed_us =
+				div_u64(ktime_get_ns() -
+					mcbsp->nq_fifo_trace_start_ns, 1000);
+			s->elapsed_us = elapsed_us > U32_MAX ?
+				U32_MAX : (u32)elapsed_us;
+			s->xbuffstat = xbuffstat;
+			s->irqst = irqst;
+			s->spcr2 = spcr2;
+			s->xccr = xccr;
+		} else {
+			mcbsp->nq_fifo_trace_dropped++;
+		}
+	}
+
+	mcbsp->nq_fifo_poll_samples++;
+	mcbsp->nq_fifo_poll_irqst_seen |= irqst;
+	mcbsp->nq_fifo_poll_spcr2_seen |= spcr2;
+
+	if (xbuffstat < mcbsp->nq_fifo_poll_min_xbuf)
+		mcbsp->nq_fifo_poll_min_xbuf = xbuffstat;
+	if (xbuffstat > mcbsp->nq_fifo_poll_max_xbuf)
+		mcbsp->nq_fifo_poll_max_xbuf = xbuffstat;
+
+	if (!xbuffstat) {
+		mcbsp->nq_fifo_poll_free0_samples++;
+		mcbsp->nq_fifo_poll_free0_run_len++;
+		if (mcbsp->nq_fifo_poll_free0_run_len == 1) {
+			mcbsp->nq_fifo_poll_free0_runs++;
+			if (!mcbsp->nq_fifo_poll_first_free0_sample)
+				mcbsp->nq_fifo_poll_first_free0_sample =
+					mcbsp->nq_fifo_poll_samples;
+		}
+		if (mcbsp->nq_fifo_poll_free0_run_len >
+		    mcbsp->nq_fifo_poll_free0_run_max)
+			mcbsp->nq_fifo_poll_free0_run_max =
+				mcbsp->nq_fifo_poll_free0_run_len;
+	} else {
+		mcbsp->nq_fifo_poll_free0_run_len = 0;
+	}
+
+	mcbsp->nq_fifo_poll_last_xbuf = xbuffstat;
+	mcbsp->nq_fifo_poll_last_irqst = irqst;
+	mcbsp->nq_fifo_poll_last_spcr2 = spcr2;
+	mcbsp->nq_fifo_poll_last_xccr = xccr;
+}
+
+static enum hrtimer_restart omap_mcbsp_nq_fifo_poll_timer(struct hrtimer *timer)
+{
+	struct omap_mcbsp *mcbsp =
+		container_of(timer, struct omap_mcbsp, nq_fifo_poll_timer);
+	unsigned int interval_ms;
+
+	if (!mcbsp->nq_fifo_poll_active)
+		return HRTIMER_NORESTART;
+
+	omap_mcbsp_nq_fifo_poll_sample(mcbsp);
+	if (!mcbsp->nq_fifo_poll_active)
+		return HRTIMER_NORESTART;
+
+	interval_ms = max_t(unsigned int, omap_mcbsp_nq_fifo_poll_ms, 1);
+	hrtimer_forward_now(timer, ms_to_ktime(interval_ms));
+
+	return HRTIMER_RESTART;
+}
+
+static void omap_mcbsp_nq_fifo_poll_start(struct omap_mcbsp *mcbsp)
+{
+	unsigned int interval_ms;
+
+	if (!omap_mcbsp_nq_fifo_poll_ms || mcbsp->nq_pio_active)
+		return;
+
+	mcbsp->nq_fifo_poll_active = true;
+	mcbsp->nq_fifo_poll_samples = 0;
+	mcbsp->nq_fifo_poll_min_xbuf = U16_MAX;
+	mcbsp->nq_fifo_poll_max_xbuf = 0;
+	mcbsp->nq_fifo_poll_last_xbuf = 0;
+	mcbsp->nq_fifo_poll_irqst_seen = 0;
+	mcbsp->nq_fifo_poll_spcr2_seen = 0;
+	mcbsp->nq_fifo_poll_last_irqst = 0;
+	mcbsp->nq_fifo_poll_last_spcr2 = 0;
+	mcbsp->nq_fifo_poll_last_xccr = 0;
+	mcbsp->nq_fifo_poll_free0_samples = 0;
+	mcbsp->nq_fifo_poll_free0_runs = 0;
+	mcbsp->nq_fifo_poll_free0_run_len = 0;
+	mcbsp->nq_fifo_poll_free0_run_max = 0;
+	mcbsp->nq_fifo_poll_first_free0_sample = 0;
+	omap_mcbsp_nq_fifo_trace_free(mcbsp);
+	if (omap_mcbsp_nq_fifo_trace_samples) {
+		mcbsp->nq_fifo_trace_capacity =
+			min_t(unsigned int, omap_mcbsp_nq_fifo_trace_samples,
+			      8192);
+		mcbsp->nq_fifo_trace =
+			kcalloc(mcbsp->nq_fifo_trace_capacity,
+				sizeof(*mcbsp->nq_fifo_trace), GFP_ATOMIC);
+		if (!mcbsp->nq_fifo_trace) {
+			dev_warn(mcbsp->dev,
+				 "nq fifo trace allocation failed samples=%u\n",
+				 mcbsp->nq_fifo_trace_capacity);
+			mcbsp->nq_fifo_trace_capacity = 0;
+		}
+	}
+	mcbsp->nq_fifo_trace_start_ns = ktime_get_ns();
+	hrtimer_cancel(&mcbsp->nq_fifo_poll_timer);
+
+	omap_mcbsp_nq_fifo_poll_sample(mcbsp);
+	interval_ms = max_t(unsigned int, omap_mcbsp_nq_fifo_poll_ms, 1);
+	hrtimer_start(&mcbsp->nq_fifo_poll_timer, ms_to_ktime(interval_ms),
+		      HRTIMER_MODE_REL);
+
+	dev_info(mcbsp->dev,
+		 "nq fifo poll start interval_ms=%u buffer_size=%u trace_samples=%u\n",
+		 interval_ms, mcbsp->pdata->buffer_size,
+		 mcbsp->nq_fifo_trace_capacity);
+}
+
+static void omap_mcbsp_nq_fifo_poll_stop(struct omap_mcbsp *mcbsp)
+{
+	if (!mcbsp->nq_fifo_poll_active)
+		return;
+
+	omap_mcbsp_nq_fifo_poll_sample(mcbsp);
+	mcbsp->nq_fifo_poll_active = false;
+	hrtimer_cancel(&mcbsp->nq_fifo_poll_timer);
+
+	dev_info(mcbsp->dev,
+		 "nq fifo poll stop samples=%lu xbuf_free_min=0x%04x xbuf_free_max=0x%04x xbuf_free_last=0x%04x free0_samples=%lu free0_runs=%lu free0_run_max=%lu first_free0_sample=%lu irqst_seen=0x%04x irqst_last=0x%04x spcr2_seen=0x%04x spcr2_last=0x%04x xccr_last=0x%04x\n",
+		 mcbsp->nq_fifo_poll_samples,
+		 mcbsp->nq_fifo_poll_min_xbuf == U16_MAX ?
+		 0 : mcbsp->nq_fifo_poll_min_xbuf,
+		 mcbsp->nq_fifo_poll_max_xbuf,
+		 mcbsp->nq_fifo_poll_last_xbuf,
+		 mcbsp->nq_fifo_poll_free0_samples,
+		 mcbsp->nq_fifo_poll_free0_runs,
+		 mcbsp->nq_fifo_poll_free0_run_max,
+		 mcbsp->nq_fifo_poll_first_free0_sample,
+		 mcbsp->nq_fifo_poll_irqst_seen,
+		 mcbsp->nq_fifo_poll_last_irqst,
+		 mcbsp->nq_fifo_poll_spcr2_seen,
+		 mcbsp->nq_fifo_poll_last_spcr2,
+		 mcbsp->nq_fifo_poll_last_xccr);
+	omap_mcbsp_nq_fifo_trace_dump(mcbsp);
+	omap_mcbsp_nq_fifo_trace_free(mcbsp);
+}
+
+static void omap_mcbsp_nq_dlb_trace_free(struct omap_mcbsp *mcbsp)
+{
+	kfree(mcbsp->nq_dlb_blocks);
+	mcbsp->nq_dlb_blocks = NULL;
+	mcbsp->nq_dlb_block_capacity = 0;
+	mcbsp->nq_dlb_blocks_seen = 0;
+	mcbsp->nq_dlb_blocks_dropped = 0;
+}
+
+static u32 omap_mcbsp_nq_dlb_block_rms(const struct omap_mcbsp_nq_dlb_block *b,
+				       unsigned int parity)
+{
+	if (!b->count[parity])
+		return 0;
+
+	return int_sqrt64(div64_u64(b->sumsq[parity], b->count[parity]));
+}
+
+static void omap_mcbsp_nq_dlb_trace_dump(struct omap_mcbsp *mcbsp,
+					 const char *phase)
+{
+	u32 blocks = min(mcbsp->nq_dlb_blocks_seen,
+			 mcbsp->nq_dlb_block_capacity);
+	u32 dump_blocks = min(blocks, omap_mcbsp_nq_dlb_dump_blocks);
+	u32 rms_min[2] = { U32_MAX, U32_MAX };
+	u32 rms_max[2] = { 0, 0 };
+	u64 rms_sum[2] = { 0, 0 };
+	u32 rms_count[2] = { 0, 0 };
+	unsigned int parity;
+	u32 i;
+
+	for (i = 0; i < blocks; i++) {
+		for (parity = 0; parity < 2; parity++) {
+			u32 rms;
+
+			if (!mcbsp->nq_dlb_blocks[i].count[parity])
+				continue;
+			rms = omap_mcbsp_nq_dlb_block_rms(
+				&mcbsp->nq_dlb_blocks[i], parity);
+			rms_min[parity] = min(rms_min[parity], rms);
+			rms_max[parity] = max(rms_max[parity], rms);
+			rms_sum[parity] += rms;
+			rms_count[parity]++;
+		}
+	}
+
+	dev_info(mcbsp->dev,
+		 "nq dlb %s words=%lu frames_target=%u elapsed_ms=%llu timed_out=%d rready_polls=%lu empty_polls=%lu sync_errors=%lu blocks_seen=%u dropped=%u p0_rms_min=%u p0_rms_max=%u p0_rms_avg=%llu p1_rms_min=%u p1_rms_max=%u p1_rms_avg=%llu\n",
+		 phase, mcbsp->nq_dlb_words, mcbsp->nq_dlb_frames_target,
+		 div_u64(ktime_get_ns() - mcbsp->nq_dlb_start_ns, 1000000),
+		 mcbsp->nq_dlb_timed_out, mcbsp->nq_dlb_rready_polls,
+		 mcbsp->nq_dlb_empty_polls, mcbsp->nq_dlb_sync_errors,
+		 mcbsp->nq_dlb_blocks_seen, mcbsp->nq_dlb_blocks_dropped,
+		 rms_count[0] ? rms_min[0] : 0, rms_max[0],
+		 rms_count[0] ? div64_u64(rms_sum[0], rms_count[0]) : 0,
+		 rms_count[1] ? rms_min[1] : 0, rms_max[1],
+		 rms_count[1] ? div64_u64(rms_sum[1], rms_count[1]) : 0);
+
+	for (i = 0; i < dump_blocks; i += 12) {
+		char line[768];
+		u32 end = min(dump_blocks, i + 12);
+		u32 j;
+		int len = 0;
+
+		for (j = i; j < end; j++) {
+			u32 rms0 = omap_mcbsp_nq_dlb_block_rms(
+				&mcbsp->nq_dlb_blocks[j], 0);
+			u32 rms1 = omap_mcbsp_nq_dlb_block_rms(
+				&mcbsp->nq_dlb_blocks[j], 1);
+
+			len += scnprintf(line + len, sizeof(line) - len,
+					 "%s%u:%u/%u",
+					 j == i ? "" : ",", j, rms0, rms1);
+		}
+
+		dev_info(mcbsp->dev,
+			 "nq dlb rms first=%u count=%u block_frames=%u data=%s\n",
+			 i, end - i, mcbsp->nq_dlb_block_frames, line);
+	}
+}
+
+static int omap_mcbsp_nq_dlb_thread_fn(void *data)
+{
+	struct omap_mcbsp *mcbsp = data;
+	unsigned long timeout_ms;
+	unsigned long deadline;
+	unsigned long target_words;
+
+	timeout_ms = div_u64((u64)mcbsp->nq_dlb_frames_target * 1000,
+			     max_t(unsigned int, mcbsp->nq_playback_rate, 1));
+	timeout_ms += 1000;
+	deadline = jiffies + msecs_to_jiffies(timeout_ms);
+	target_words = (unsigned long)mcbsp->nq_dlb_frames_target * 2;
+
+	while (!kthread_should_stop() && mcbsp->nq_dlb_words < target_words) {
+		u16 spcr1 = MCBSP_READ(mcbsp, SPCR1);
+
+		if (time_after(jiffies, deadline)) {
+			mcbsp->nq_dlb_timed_out = true;
+			break;
+		}
+
+		if (spcr1 & RSYNC_ERR) {
+			mcbsp->nq_dlb_sync_errors++;
+			MCBSP_WRITE(mcbsp, SPCR1, MCBSP_READ_CACHE(mcbsp, SPCR1));
+		}
+
+		if (spcr1 & RRDY) {
+			unsigned long word = mcbsp->nq_dlb_words++;
+			unsigned int parity = word & 1;
+			unsigned int frame = word >> 1;
+			unsigned int block = div_u64(frame,
+						     mcbsp->nq_dlb_block_frames);
+			s16 sample = (s16)MCBSP_READ(mcbsp, DRR);
+			s32 sample32 = sample;
+
+			mcbsp->nq_dlb_rready_polls++;
+			if (block < mcbsp->nq_dlb_block_capacity) {
+				struct omap_mcbsp_nq_dlb_block *b =
+					&mcbsp->nq_dlb_blocks[block];
+
+				b->sumsq[parity] += (s64)sample32 * sample32;
+				b->count[parity]++;
+				if (block + 1 > mcbsp->nq_dlb_blocks_seen)
+					mcbsp->nq_dlb_blocks_seen = block + 1;
+			} else {
+				mcbsp->nq_dlb_blocks_dropped++;
+			}
+		} else {
+			mcbsp->nq_dlb_empty_polls++;
+			udelay(1);
+		}
+
+		if (!(mcbsp->nq_dlb_rready_polls & 0x3ff))
+			cond_resched();
+	}
+
+	omap_mcbsp_nq_dlb_trace_dump(mcbsp, "done");
+
+	return 0;
+}
+
+static void omap_mcbsp_nq_dlb_trace_start(struct omap_mcbsp *mcbsp)
+{
+	unsigned int frames = omap_mcbsp_nq_dlb_trace_frames;
+	unsigned int block_frames;
+	unsigned int blocks;
+	u16 spcr1;
+	u16 rccr;
+
+	if (!frames)
+		return;
+	if (mcbsp->nq_dlb_active)
+		return;
+	if (mcbsp->nq_playback_channels != 2 || mcbsp->nq_playback_wlen != 16 ||
+	    !mcbsp->nq_playback_rate) {
+		dev_warn(mcbsp->dev,
+			 "nq dlb skipped rate=%u channels=%u wlen=%u\n",
+			 mcbsp->nq_playback_rate, mcbsp->nq_playback_channels,
+			 mcbsp->nq_playback_wlen);
+		return;
+	}
+
+	block_frames = clamp_t(unsigned int,
+			       omap_mcbsp_nq_dlb_block_frames, 1, frames);
+	blocks = DIV_ROUND_UP(frames, block_frames);
+	blocks = min_t(unsigned int, blocks, 512);
+
+	omap_mcbsp_nq_dlb_trace_free(mcbsp);
+	mcbsp->nq_dlb_blocks = kcalloc(blocks, sizeof(*mcbsp->nq_dlb_blocks),
+				       GFP_ATOMIC);
+	if (!mcbsp->nq_dlb_blocks) {
+		dev_warn(mcbsp->dev, "nq dlb allocation failed blocks=%u\n",
+			 blocks);
+		return;
+	}
+
+	mcbsp->nq_dlb_active = true;
+	mcbsp->nq_dlb_timed_out = false;
+	mcbsp->nq_dlb_saved_spcr1 = MCBSP_READ(mcbsp, SPCR1);
+	mcbsp->nq_dlb_saved_rccr = mcbsp->pdata->has_ccr ?
+		MCBSP_READ(mcbsp, RCCR) : 0;
+	mcbsp->nq_dlb_start_ns = ktime_get_ns();
+	mcbsp->nq_dlb_words = 0;
+	mcbsp->nq_dlb_rready_polls = 0;
+	mcbsp->nq_dlb_empty_polls = 0;
+	mcbsp->nq_dlb_sync_errors = 0;
+	mcbsp->nq_dlb_frames_target = frames;
+	mcbsp->nq_dlb_block_frames = block_frames;
+	mcbsp->nq_dlb_block_capacity = blocks;
+
+	spcr1 = MCBSP_READ_CACHE(mcbsp, SPCR1) | DLB | RRST;
+	MCBSP_WRITE(mcbsp, SPCR1, spcr1);
+	if (mcbsp->pdata->has_ccr) {
+		rccr = MCBSP_READ(mcbsp, RCCR) & ~RDISABLE;
+		MCBSP_WRITE(mcbsp, RCCR, rccr);
+	}
