+	count = ++c->nq_irq_count;
+	error = status & (CICR_DROP_IE | CICR_TRANS_ERR_IE |
+			  CICR_MISALIGNED_ERR_IE);
+	if (count > omap_dma_nq_dump_irq_limit && !error)
+		return;
+
+	if (!dma_omap1()) {
+		irqenable_l1 = omap_dma_glbl_read(od, IRQENABLE_L1);
+		irqstatus_l1 = omap_dma_glbl_read(od, IRQSTATUS_L1);
+	}
+
+	dev_info(c->vc.chan.device->dev,
+		 "nq dma-irq ch=%d sig=%u dir=%d count=%u status=0x%04x ccr=0x%08x csr=0x%04x cen=%u cfn=%u cssa=0x%08x cdsa=0x%08x csac=0x%08x cdac=0x%08x clnk=0x%04x irq_mask=0x%08x irqenable_l1=0x%08x irqstatus_l1=0x%08x\n",
