# Keep the UDC free for the initramfs configfs ACM+ECM gadget. The legacy
# built-in g_ether gadget binds early and exposes RNDIS as configuration 1,
# which macOS sees over USB but does not expose as a BSD network interface.
# CONFIG_USB_G_SERIAL is not set
# CONFIG_USB_ETH is not set
# CONFIG_USB_ETH_RNDIS is not set
# CONFIG_USB_ETH_EEM is not set
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_F_ACM=y
CONFIG_USB_F_ECM=y
CONFIG_USB_U_ETHER=y
